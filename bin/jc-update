#!/usr/bin/env bash
# jc-update — Check and apply framework updates.
#
# Usage:
#   jc update [--check-only] [--yes] [--instance-dir path]
#
# Behavior:
#   - Fetches latest release version from GitHub
#   - Compares with current local version
#   - If newer, offers to pull and restart watchdog
#   - Runs CalVer release hooks from updates/releases/

set -euo pipefail

usage() {
    cat <<'EOF'
jc-update — Check and apply framework updates.

Usage:
  jc update [--check-only] [--yes] [--instance-dir path]

Options:
  --check-only   Only report whether an update is available.
  --yes          Apply without prompting.
  --instance-dir Path to the instance that should receive release hooks.
  -h, --help     Show this help.
EOF
}

SCRIPT_DIR=$(cd "$(dirname "$0")" && pwd)
JC_ROOT=$(cd "$SCRIPT_DIR/.." && pwd)

# Parse args
CHECK_ONLY=0
ASSUME_YES=0
INSTANCE_DIR=""
CALLING_CWD="$(pwd)"
while (( $# )); do
    case "$1" in
        -h|--help|help)
            usage
            exit 0
            ;;
        --check-only)
            CHECK_ONLY=1
            shift
            ;;
        --yes|-y)
            ASSUME_YES=1
            shift
            ;;
        --instance-dir)
            if [[ $# -lt 2 ]]; then
                echo "--instance-dir requires a path" >&2
                exit 2
            fi
            INSTANCE_DIR="$2"
            shift 2
            ;;
        --instance-dir=*)
            INSTANCE_DIR="${1#--instance-dir=}"
            shift
            ;;
        *)
            echo "Unknown option: $1" >&2
            usage >&2
            exit 2
            ;;
    esac
done

# Get local version from pyproject.toml
get_local_version() {
    grep '^version = ' "$JC_ROOT/pyproject.toml" | sed 's/^version = "\(.*\)"/\1/'
}

# Get latest release version from GitHub API
get_remote_version() {
    timeout 5 curl -s https://api.github.com/repos/matsei-ruka/juliuscaesar/releases/latest \
        | grep '"tag_name"' | head -1 | sed 's/.*"v\([^"]*\)".*/\1/' || echo ""
}

run_release_hooks() {
    local from_version="$1"
    local to_version="$2"
    local hooks_dir="$JC_ROOT/updates/releases"

    if [[ ! -d "$hooks_dir" ]]; then
        echo "No release hooks directory found."
        return 0
    fi

    local hooks
    hooks=$(
        python3 - "$hooks_dir" "$from_version" "$to_version" <<'PY'
from __future__ import annotations

import re
import sys
from pathlib import Path

hooks_dir = Path(sys.argv[1])
from_version = sys.argv[2]
to_version = sys.argv[3]

def parts(value: str) -> tuple[int, ...]:
    return tuple(int(piece) for piece in re.findall(r"\d+", value))

start = parts(from_version)
target = parts(to_version)

for hook in sorted(hooks_dir.glob("*.sh"), key=lambda path: parts(path.stem)):
    version = parts(hook.stem)
    if start == target:
        include = version == target
    else:
        include = start < version <= target
    if include:
        print(hook)
PY
    )

    if [[ -z "$hooks" ]]; then
        echo "No release hooks to run for $from_version -> $to_version."
        return 0
    fi

    echo "Running release hooks for $from_version -> $to_version..."
    export JC_FRAMEWORK_ROOT="$JC_ROOT"
    export JC_UPDATE_CALLING_CWD="$CALLING_CWD"
    while IFS= read -r hook; do
        [[ -z "$hook" ]] && continue
        echo "-> $(basename "$hook" .sh)"
        if [[ -n "$INSTANCE_DIR" ]]; then
            "$hook" --from-version "$from_version" --to-version "$to_version" --instance-dir "$INSTANCE_DIR"
        else
            "$hook" --from-version "$from_version" --to-version "$to_version"
        fi
    done <<< "$hooks"
}

reload_watchdog() {
    echo "Reloading watchdog..."
    if command -v jc-watchdog >/dev/null 2>&1; then
        jc-watchdog reload || true
    fi
}

LOCAL=$(get_local_version)
echo "Local version: $LOCAL"

echo "Checking GitHub for updates..."
REMOTE=$(get_remote_version)

if [[ -z "$REMOTE" ]]; then
    echo "Could not fetch remote version. Check your internet connection." >&2
    exit 1
fi

echo "Latest version: $REMOTE"

if [[ "$LOCAL" == "$REMOTE" ]]; then
    echo "Already up-to-date."
    if [[ "$CHECK_ONLY" == 1 ]]; then
        exit 0
    fi
    run_release_hooks "$LOCAL" "$LOCAL"
    reload_watchdog
    exit 0
fi

if [[ "$CHECK_ONLY" == 1 ]]; then
    echo "Update available: $LOCAL → $REMOTE"
    exit 0
fi

echo ""
echo "⚠️  Update available: $LOCAL → $REMOTE"
if [[ "$ASSUME_YES" != 1 ]]; then
    read -p "Pull latest main with fast-forward only? [y/N] " -r
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        echo "Cancelled."
        exit 0
    fi
fi

echo "Pulling latest code..."
cd "$JC_ROOT"
git fetch origin
git merge --ff-only origin/main

UPDATED=$(get_local_version)
run_release_hooks "$LOCAL" "$UPDATED"
reload_watchdog

echo "✓ Update complete. Version $UPDATED deployed."
