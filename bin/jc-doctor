#!/usr/bin/env bash
# jc-doctor — diagnose a JuliusCaesar instance + environment.
#
# Checks prereqs (binaries, python, ffmpeg), instance structure,
# credentials, voice enrollment, watchdog install state, and the
# runtime claude + plugin processes. Per-check green / yellow / red.
#
# Exits non-zero if any RED checks fail (useful in CI / pre-flight).

set -uo pipefail

FRAMEWORK_ROOT="$(cd "$(dirname "$(readlink -f "$0" 2>/dev/null || echo "$0")")/.." && pwd)"
VENV_PYTHON="${XDG_DATA_HOME:-$HOME/.local/share}/juliuscaesar/venv/bin/python"
if [[ -x "${JULIUSCAESAR_PYTHON:-}" ]]; then
    JC_PYTHON="$JULIUSCAESAR_PYTHON"
elif [[ -x "$VENV_PYTHON" ]]; then
    JC_PYTHON="$VENV_PYTHON"
else
    JC_PYTHON="$(command -v python3 || true)"
fi

# --- Colors ---
if [[ -t 1 ]]; then
    RED=$'\033[0;31m'; YEL=$'\033[0;33m'; GRN=$'\033[0;32m'; DIM=$'\033[0;37m'; RST=$'\033[0m'
else
    RED=''; YEL=''; GRN=''; DIM=''; RST=''
fi

FAIL=0
FIX=0

ok()   { printf '%s✓%s %s\n' "$GRN" "$RST" "$*"; }
warn() { printf '%s!%s %s\n' "$YEL" "$RST" "$*"; }
fail() { printf '%s✗%s %s\n' "$RED" "$RST" "$*"; FAIL=$((FAIL+1)); }
info() { printf '%s·%s %s\n' "$DIM" "$RST" "$*"; }
section() { printf '\n%s%s%s\n' "$GRN" "$*" "$RST"; }
fixed() { printf '%s→%s fixed: %s\n' "$GRN" "$RST" "$*"; }

file_mode() {
    local path="$1"
    stat -c '%a' "$path" 2>/dev/null || stat -f '%Lp' "$path" 2>/dev/null || echo "unknown"
}

proc_cwd() {
    local pid="$1"
    local cwd=""
    cwd=$(readlink -f "/proc/$pid/cwd" 2>/dev/null || true)
    if [[ -n "$cwd" ]]; then
        echo "$cwd"
        return 0
    fi
    if command -v lsof >/dev/null 2>&1; then
        lsof -a -p "$pid" -d cwd -Fn 2>/dev/null | awk '/^n/ { print substr($0, 2); exit }'
    fi
}

proc_ppid() {
    local pid="$1"
    ps -o ppid= -p "$pid" 2>/dev/null | awk '{ print $1; exit }'
}

pid_descends_from_any() {
    local pid="$1"
    shift
    (( $# > 0 )) || return 1
    local ppid ancestor
    while :; do
        ppid=$(proc_ppid "$pid")
        [[ -n "$ppid" && "$ppid" != "0" && "$ppid" != "1" ]] || return 1
        for ancestor in "$@"; do
            [[ "$ppid" == "$ancestor" ]] && return 0
        done
        pid="$ppid"
    done
}

version_probe() {
    local bin="$1"
    if command -v timeout >/dev/null 2>&1; then
        timeout 3 "$bin" --version 2>/dev/null | head -1 || true
    else
        "$bin" --version 2>/dev/null | head -1 || true
    fi
}

load_env_file() {
    local file="$1"
    local line key value
    [[ -f "$file" ]] || return 0
    while IFS= read -r line || [[ -n "$line" ]]; do
        line="${line%$'\r'}"
        [[ -z "${line//[[:space:]]/}" || "$line" =~ ^[[:space:]]*# ]] && continue
        [[ "$line" == *"="* ]] || continue
        key="${line%%=*}"
        value="${line#*=}"
        key="${key#"${key%%[![:space:]]*}"}"
        key="${key%"${key##*[![:space:]]}"}"
        case "$key" in
            DASHSCOPE_API_KEY|TELEGRAM_BOT_TOKEN|TELEGRAM_CHAT_ID|SLACK_APP_TOKEN|SLACK_BOT_TOKEN) ;;
            *) continue ;;
        esac
        value="${value#"${value%%[![:space:]]*}"}"
        if [[ "$value" == \'* && "$value" == *\' ]]; then
            value="${value:1:${#value}-2}"
        elif [[ "$value" == \"* && "$value" == *\" ]]; then
            value="${value:1:${#value}-2}"
        fi
        export "$key=$value"
    done < "$file"
}

# --- Instance resolution ---
INSTANCE_DIR=""
while (( $# )); do
    case "$1" in
        --fix) FIX=1; shift ;;
        --instance-dir) INSTANCE_DIR="${2:-}"; shift 2 ;;
        --instance-dir=*) INSTANCE_DIR="${1#*=}"; shift ;;
        *) shift ;;
    esac
done

if [[ -z "$INSTANCE_DIR" ]]; then
    # env > walk-up > cwd
    if [[ -n "${JC_INSTANCE_DIR:-}" && -d "$JC_INSTANCE_DIR" ]]; then
        INSTANCE_DIR="$JC_INSTANCE_DIR"
    else
        cur="$(pwd)"
        while :; do
            [[ -f "$cur/.jc" ]] && { INSTANCE_DIR="$cur"; break; }
            [[ "$(dirname "$cur")" == "$cur" ]] && break
            cur="$(dirname "$cur")"
        done
        [[ -z "$INSTANCE_DIR" && -d "$(pwd)/memory" ]] && INSTANCE_DIR="$(pwd)"
    fi
fi

# --- Environment checks ---

section "Environment"

for bin in python3 bash curl screen ffmpeg git; do
    if command -v "$bin" >/dev/null 2>&1; then
        ok "$bin found: $(command -v "$bin")"
    else
        fail "$bin missing (required)"
    fi
done

if command -v claude >/dev/null 2>&1; then
    ok "claude CLI: $(command -v claude) ($(claude --version 2>/dev/null | head -1 || echo 'version unknown'))"
else
    fail "claude CLI not on PATH (https://www.anthropic.com/claude-code)"
fi

# --- JC binaries ---

section "JuliusCaesar binaries"

for b in jc jc-memory jc-heartbeat jc-voice jc-watchdog jc-workers jc-gateway jc-init jc-setup jc-doctor jc-email; do
    if command -v "$b" >/dev/null 2>&1; then
        ok "$b"
    else
        fail "$b missing — run install.sh from the juliuscaesar repo"
    fi
done

# --- Adapter CLIs (optional, only warn) ---

section "Adapter CLIs (optional — only needed per your tasks.yaml)"

for b in gemini opencode codex; do
    if command -v "$b" >/dev/null 2>&1; then
        ver=$(version_probe "$b")
        if [[ -n "$ver" ]]; then
            ok "$b: $(command -v "$b") ($ver)"
        else
            ok "$b found: $(command -v "$b") (version probe failed)"
        fi
    else
        info "$b not installed (only needed if a task uses it)"
    fi
done

if "$JC_PYTHON" - <<'PY' >/dev/null 2>&1
import websocket
PY
then
    ok "python websocket-client available (needed for Slack Socket Mode)"
else
    info "python websocket-client not installed (needed only for Slack Socket Mode; install.sh installs it)"
fi

# --- Instance ---

section "Instance"

if [[ -z "$INSTANCE_DIR" ]]; then
    fail "No instance dir found. Use --instance-dir, set JC_INSTANCE_DIR, or run from inside an instance."
    echo ""
    [[ $FAIL -gt 0 ]] && exit 1 || exit 0
fi
INSTANCE_DIR="$(cd "$INSTANCE_DIR" && pwd)"
ok "instance: $INSTANCE_DIR"

if [[ -f "$INSTANCE_DIR/.jc" ]]; then
    ok ".jc marker present"
else
    warn ".jc marker missing — auto-discovery may fail from other dirs"
fi

if [[ -f "$INSTANCE_DIR/ops/gateway.yaml" ]]; then
    GATEWAY_CONFIG_CHECK=$(PYTHONPATH="$FRAMEWORK_ROOT/lib${PYTHONPATH:+:$PYTHONPATH}" "$JC_PYTHON" - "$INSTANCE_DIR" <<'PY' 2>&1
import sys
from pathlib import Path
from gateway.config import validate_config

validate_config(Path(sys.argv[1]))
PY
)
    if [[ $? -eq 0 ]]; then
        ok "gateway config valid"
    else
        fail "gateway config invalid: $GATEWAY_CONFIG_CHECK"
    fi
else
    warn "ops/gateway.yaml missing — run: jc gateway init"
fi

# Directory structure
for d in memory memory/L1 memory/L2 heartbeat voice; do
    if [[ -d "$INSTANCE_DIR/$d" ]]; then
        ok "$d/ present"
    else
        warn "$d/ missing (did you run jc init?)"
    fi
done

# Memory content
if [[ -d "$INSTANCE_DIR/memory/L1" ]]; then
    L1_COUNT=$(find "$INSTANCE_DIR/memory/L1" -maxdepth 1 -name '*.md' | wc -l)
    if [[ "$L1_COUNT" -ge 3 ]]; then
        ok "memory/L1: $L1_COUNT files"
    else
        warn "memory/L1: only $L1_COUNT files (expect at least IDENTITY, USER, RULES, HOT)"
    fi
fi

if [[ -f "$INSTANCE_DIR/memory/index.sqlite" ]]; then
    SIZE=$(du -h "$INSTANCE_DIR/memory/index.sqlite" | awk '{print $1}')
    ok "memory/index.sqlite: $SIZE"
else
    if [[ "$FIX" == 1 && -d "$INSTANCE_DIR/memory" && -x "$FRAMEWORK_ROOT/bin/jc-memory" ]]; then
        if "$FRAMEWORK_ROOT/bin/jc-memory" --instance-dir "$INSTANCE_DIR" rebuild >/dev/null 2>&1; then
            SIZE=$(du -h "$INSTANCE_DIR/memory/index.sqlite" 2>/dev/null | awk '{print $1}')
            fixed "memory/index.sqlite rebuilt${SIZE:+ ($SIZE)}"
        else
            fail "memory/index.sqlite missing and rebuild failed"
        fi
    else
        warn "memory/index.sqlite missing — run: jc memory rebuild"
    fi
fi

# Heartbeat
if [[ -f "$INSTANCE_DIR/heartbeat/tasks.yaml" ]]; then
    TASK_COUNT=$(grep -cE '^[[:space:]]{2}[a-zA-Z_][a-zA-Z0-9_]*:[[:space:]]*$' "$INSTANCE_DIR/heartbeat/tasks.yaml" || true)
    ok "heartbeat/tasks.yaml: $TASK_COUNT task(s) defined"

    # Validate destinations if the block is present
    DEST_CHECK=$("$JC_PYTHON" - "$INSTANCE_DIR/heartbeat/tasks.yaml" <<'PY' 2>&1
import sys
try:
    import yaml
except ImportError:
    sys.exit(0)
try:
    with open(sys.argv[1]) as f:
        cfg = yaml.safe_load(f) or {}
except Exception as e:
    print(f"YAML_ERROR:{e}")
    sys.exit(0)

destinations = cfg.get("destinations") or {}
defaults = cfg.get("defaults") or {}
tasks = cfg.get("tasks") or {}

if not destinations and not defaults.get("destination") and not any(
    (t or {}).get("destination") for t in tasks.values()
):
    sys.exit(0)

errors = []
warnings = []

# Check destinations schema
for name, d in destinations.items():
    if not isinstance(d, dict):
        errors.append(f"destination '{name}' is not a mapping")
        continue
    if "chat_id" not in d:
        errors.append(f"destination '{name}' is missing chat_id")
    if d.get("channel") and d["channel"] != "telegram":
        warnings.append(f"destination '{name}' channel='{d['channel']}' (only 'telegram' supported in 0.1.x)")

# Check all referenced names exist
referenced = set()
raw = defaults.get("destination")
if raw:
    referenced.update([raw] if isinstance(raw, str) else list(raw or []))
for tname, t in tasks.items():
    raw = (t or {}).get("destination")
    if raw:
        referenced.update([raw] if isinstance(raw, str) else list(raw or []))

unknown = referenced - set(destinations.keys())
for u in sorted(unknown):
    errors.append(f"task references unknown destination '{u}'")

used = set()
for tname, t in tasks.items():
    raw = (t or {}).get("destination") or defaults.get("destination")
    if raw:
        used.update([raw] if isinstance(raw, str) else list(raw or []))
unused = set(destinations.keys()) - used
for u in sorted(unused):
    warnings.append(f"destination '{u}' is defined but never referenced")

print(f"TOTAL:{len(destinations)}")
for e in errors:
    print(f"ERROR:{e}")
for w in warnings:
    print(f"WARN:{w}")
PY
)
    while IFS= read -r line; do
        case "$line" in
            TOTAL:*) n=${line#TOTAL:}; ok "heartbeat destinations: $n defined" ;;
            ERROR:*) fail "destinations: ${line#ERROR:}" ;;
            WARN:*) warn "destinations: ${line#WARN:}" ;;
            YAML_ERROR:*) fail "tasks.yaml parse error: ${line#YAML_ERROR:}" ;;
        esac
    done <<<"$DEST_CHECK"
fi

# Voice
if [[ -f "$INSTANCE_DIR/voice/references/voice.json" ]]; then
    if command -v python3 >/dev/null 2>&1; then
        VOICE_ID=$("$JC_PYTHON" -c "import json; d=json.load(open('$INSTANCE_DIR/voice/references/voice.json')); print(d.get('voice', '<malformed>'))" 2>/dev/null || echo '<unreadable>')
        ok "voice enrolled: $VOICE_ID"
    else
        ok "voice enrolled (couldn't parse without python3)"
    fi
else
    info "voice not enrolled (optional — run: jc voice enroll <sample>)"
fi

# --- Credentials ---

section "Credentials"

if [[ ! -f "$INSTANCE_DIR/.env" ]]; then
    fail ".env missing at $INSTANCE_DIR/.env"
else
    ENV_MODE=$(file_mode "$INSTANCE_DIR/.env")
    if [[ "$ENV_MODE" != "600" ]]; then
        if [[ "$FIX" == 1 ]]; then
            chmod 600 "$INSTANCE_DIR/.env" && fixed ".env permissions set to 600"
            ENV_MODE=$(file_mode "$INSTANCE_DIR/.env")
        else
            warn ".env exists ($ENV_MODE permissions; expected 600)"
        fi
    fi
    ok ".env exists ($ENV_MODE permissions)"
    load_env_file "$INSTANCE_DIR/.env"

    # DashScope
    if [[ -n "${DASHSCOPE_API_KEY:-}" ]]; then
        # Ping getMe-equivalent for DashScope
        ok "DASHSCOPE_API_KEY set (prefix: ${DASHSCOPE_API_KEY:0:6}…)"
    else
        info "DASHSCOPE_API_KEY not set (required for voice)"
    fi

    # Telegram
    if [[ -n "${TELEGRAM_BOT_TOKEN:-}" ]]; then
        TG_RESP=$(curl -sS --max-time 5 "https://api.telegram.org/bot${TELEGRAM_BOT_TOKEN}/getMe" || echo '')
        if echo "$TG_RESP" | grep -q '"ok":true'; then
            BOT_NAME=$(echo "$TG_RESP" | "$JC_PYTHON" -c 'import sys,json; print(json.load(sys.stdin)["result"].get("username","?"))' 2>/dev/null || echo '?')
            ok "TELEGRAM_BOT_TOKEN valid (bot: @$BOT_NAME)"
        else
            fail "TELEGRAM_BOT_TOKEN set but getMe failed"
        fi
    else
        info "TELEGRAM_BOT_TOKEN not set (required for notifications)"
    fi

    if [[ -n "${TELEGRAM_CHAT_ID:-}" ]]; then
        ok "TELEGRAM_CHAT_ID set: $TELEGRAM_CHAT_ID"
    elif [[ -n "${TELEGRAM_BOT_TOKEN:-}" ]]; then
        warn "TELEGRAM_CHAT_ID not set (token is set but messages can't be delivered)"
    fi

    # Slack
    if [[ -n "${SLACK_APP_TOKEN:-}" || -n "${SLACK_BOT_TOKEN:-}" ]]; then
        if [[ -z "${SLACK_APP_TOKEN:-}" || -z "${SLACK_BOT_TOKEN:-}" ]]; then
            warn "Slack Socket Mode needs both SLACK_APP_TOKEN and SLACK_BOT_TOKEN"
        else
            SLACK_AUTH=$(curl -sS --max-time 5 -X POST \
                -H "Authorization: Bearer ${SLACK_BOT_TOKEN}" \
                -H "Content-Type: application/json" \
                https://slack.com/api/auth.test || echo '')
            if echo "$SLACK_AUTH" | grep -q '"ok":true'; then
                ok "SLACK_BOT_TOKEN valid"
            else
                fail "SLACK_BOT_TOKEN set but Slack auth.test failed"
            fi
        fi
    else
        info "Slack tokens not set (required only for Slack channel)"
    fi
fi

# --- Watchdog + runtime ---

section "Runtime (watchdog)"

RUNTIME_MODE="legacy-claude"
if [[ -f "$INSTANCE_DIR/ops/watchdog.conf" ]]; then
    raw_mode=$(awk -F= '$1 == "RUNTIME_MODE" { print $2; exit }' "$INSTANCE_DIR/ops/watchdog.conf")
    raw_mode="${raw_mode%\"}"; raw_mode="${raw_mode#\"}"
    raw_mode="${raw_mode%\'}"; raw_mode="${raw_mode#\'}"
    [[ -n "$raw_mode" ]] && RUNTIME_MODE="$raw_mode"
fi
ok "watchdog runtime mode: $RUNTIME_MODE"

TAG="# jc-watchdog for $INSTANCE_DIR"
if crontab -l 2>/dev/null | grep -qF "$TAG"; then
    ok "watchdog cron entries installed"
else
    info "watchdog cron not installed (optional — run: jc watchdog install)"
fi

if [[ "$RUNTIME_MODE" == "gateway" ]]; then
    info "legacy live Claude/plugin checks skipped in gateway mode"
    PIDFILE="$HOME/.claude/channels/telegram/bot.pid"
    if [[ -n "${TELEGRAM_BOT_TOKEN:-}" && -f "$PIDFILE" ]]; then
        PID=$(cat "$PIDFILE" 2>/dev/null)
        if [[ -n "$PID" ]] && kill -0 "$PID" 2>/dev/null; then
            warn "legacy Claude Telegram plugin pidfile is alive (pid $PID); stop it before using the same bot token with gateway"
        elif [[ "$FIX" == 1 ]]; then
            rm -f "$PIDFILE"
            fixed "removed stale legacy Telegram plugin pidfile"
        else
            warn "legacy Claude Telegram plugin pidfile is stale: $PIDFILE"
        fi
    fi
else
# Live claude
# Scope to THIS instance: claude whose cwd is INSTANCE_DIR. Multi-instance
# hosts can have several unrelated claude sessions running; count only ours.
OUR_CLAUDE_PID=""
OUR_CLAUDE_PIDS=""
for pid in $(pgrep -f "claude .*--channels plugin:telegram" 2>/dev/null); do
    cwd=$(proc_cwd "$pid")
    if [[ "$cwd" == "$INSTANCE_DIR" ]]; then
        OUR_CLAUDE_PIDS="${OUR_CLAUDE_PIDS}${OUR_CLAUDE_PIDS:+ }$pid"
        [[ -z "$OUR_CLAUDE_PID" ]] && OUR_CLAUDE_PID="$pid"
    fi
done
if [[ -n "$OUR_CLAUDE_PID" ]]; then
    ok "live claude process running (pid $OUR_CLAUDE_PID, cwd $INSTANCE_DIR)"
else
    info "no interactive claude session detected for this instance (start one with: claude --channels plugin:telegram@claude-plugins-official)"
fi

# Telegram plugin health
PIDFILE="$HOME/.claude/channels/telegram/bot.pid"
if [[ -n "${TELEGRAM_BOT_TOKEN:-}" ]]; then
    if [[ ! -f "$PIDFILE" ]]; then
        warn "telegram plugin bot.pid missing (plugin may not be running)"
    else
        PID=$(cat "$PIDFILE" 2>/dev/null)
        if [[ -n "$PID" ]] && kill -0 "$PID" 2>/dev/null; then
            if [[ -n "$OUR_CLAUDE_PIDS" ]] && pid_descends_from_any "$PID" $OUR_CLAUDE_PIDS; then
                ok "telegram plugin alive and owned by this instance (pid $PID)"
            elif [[ -n "$OUR_CLAUDE_PIDS" ]]; then
                fail "telegram plugin pid $PID is alive but not owned by this instance's claude; watchdog should restart to reclaim Telegram"
            else
                warn "telegram plugin pid $PID is alive but no live claude session was detected for this instance"
            fi
        else
            fail "telegram plugin dead (pid $PID). Restart claude to respawn."
        fi
    fi
fi
fi

# --- Gateway ---

section "Gateway"

GATEWAY_CONFIG="$INSTANCE_DIR/ops/gateway.yaml"
if [[ -f "$GATEWAY_CONFIG" ]]; then
    ok "gateway config present: $GATEWAY_CONFIG"
    GATEWAY_CONFIG_CHECK=$(PYTHONPATH="$FRAMEWORK_ROOT/lib" "$JC_PYTHON" - "$INSTANCE_DIR" <<'PY' 2>&1
from pathlib import Path
import sys
from gateway.config import load_config, SUPPORTED_BRAINS

try:
    cfg = load_config(Path(sys.argv[1]))
except Exception as exc:
    print(f"ERROR:{exc}")
    raise SystemExit(0)
print(f"BRAIN:{cfg.default_brain}")
for name, ch in cfg.channels.items():
    print(f"CHANNEL:{name}:{'enabled' if ch.enabled else 'disabled'}")
if cfg.default_brain not in SUPPORTED_BRAINS:
    print(f"ERROR:unsupported default brain {cfg.default_brain}")
PY
)
    while IFS= read -r line; do
        case "$line" in
            BRAIN:*) ok "gateway default brain: ${line#BRAIN:}" ;;
            CHANNEL:*) info "gateway ${line#CHANNEL:}" ;;
            ERROR:*) fail "gateway config: ${line#ERROR:}" ;;
        esac
    done <<<"$GATEWAY_CONFIG_CHECK"
else
    if [[ "$FIX" == 1 ]]; then
        mkdir -p "$INSTANCE_DIR/ops"
        PYTHONPATH="$FRAMEWORK_ROOT/lib" "$JC_PYTHON" - "$INSTANCE_DIR" <<'PY'
from pathlib import Path
import sys
from gateway.config import render_default_config

target = Path(sys.argv[1])
target.joinpath("ops", "gateway.yaml").write_text(render_default_config(), encoding="utf-8")
PY
        fixed "gateway config created at $GATEWAY_CONFIG"
    else
        warn "gateway config missing (run: jc setup, or jc doctor --fix for defaults)"
    fi
fi

GATEWAY_DB="$INSTANCE_DIR/state/gateway/queue.db"
if [[ -f "$GATEWAY_DB" ]]; then
    SIZE=$(du -h "$GATEWAY_DB" | awk '{print $1}')
    ok "gateway queue present: $SIZE"
    GATEWAY_COUNTS=$("$JC_PYTHON" - "$GATEWAY_DB" <<'PY' 2>&1
import sqlite3
import sys

try:
    conn = sqlite3.connect(sys.argv[1])
    rows = conn.execute("SELECT status, COUNT(*) FROM events GROUP BY status").fetchall()
except Exception as exc:
    print(f"ERROR:{exc}")
    sys.exit(0)

if rows:
    print(", ".join(f"{status}={count}" for status, count in rows))
else:
    print("empty")
PY
)
    if [[ "$GATEWAY_COUNTS" == ERROR:* ]]; then
        fail "gateway queue unreadable: ${GATEWAY_COUNTS#ERROR:}"
    else
        ok "gateway events: $GATEWAY_COUNTS"
    fi
else
    if [[ "$FIX" == 1 ]]; then
        GATEWAY_INIT=$(PYTHONPATH="$FRAMEWORK_ROOT/lib" "$JC_PYTHON" - "$INSTANCE_DIR" <<'PY' 2>&1
from pathlib import Path
import sys
from gateway import queue

instance = Path(sys.argv[1])
conn = queue.connect(instance)
conn.close()
print(queue.queue_path(instance))
PY
)
        if [[ "$GATEWAY_INIT" == *"Traceback"* || -z "$GATEWAY_INIT" ]]; then
            fail "gateway queue initialization failed: $GATEWAY_INIT"
        else
            fixed "gateway queue initialized at $GATEWAY_INIT"
        fi
    else
        info "gateway queue not initialized (optional — run: jc gateway init)"
    fi
fi

GATEWAY_PIDFILE="$INSTANCE_DIR/state/gateway/jc-gateway.pid"
if [[ -f "$GATEWAY_PIDFILE" ]]; then
    GATEWAY_PID=$(cat "$GATEWAY_PIDFILE" 2>/dev/null)
    if [[ -n "$GATEWAY_PID" ]] && kill -0 "$GATEWAY_PID" 2>/dev/null; then
        ok "gateway daemon running (pid $GATEWAY_PID)"
    elif [[ "$FIX" == 1 ]]; then
        rm -f "$GATEWAY_PIDFILE"
        fixed "removed stale gateway pidfile"
    else
        warn "gateway pidfile is stale: $GATEWAY_PIDFILE"
    fi
fi

# --- Email channel ---

section "Email channel"

EMAIL_CHECK=$(PYTHONPATH="$FRAMEWORK_ROOT/lib" "$JC_PYTHON" - "$INSTANCE_DIR" <<'PY' 2>&1
from pathlib import Path
import sys
from gateway.config import env_values
from gateway.channels import email_state
try:
    import yaml
except Exception:
    yaml = None

instance = Path(sys.argv[1])
cfg = {}
path = instance / "ops" / "gateway.yaml"
if yaml and path.exists():
    data = yaml.safe_load(path.read_text(encoding="utf-8")) or {}
    channels = data.get("channels") if isinstance(data, dict) else {}
    cfg = (channels or {}).get("email") or {}
enabled = bool(cfg.get("enabled", False)) if isinstance(cfg, dict) else False
env = env_values(instance)
metrics = email_state.metrics(instance)
print(f"ENABLED:{enabled}")
for key in ("IMAP_HOST", "IMAP_USER", "IMAP_PASSWORD"):
    print(f"CRED:{key}:{'ok' if env.get(key) else 'missing'}")
print(f"METRIC:last_uid:{metrics['last_uid']}")
print(f"METRIC:pending:{metrics['pending']}")
print(f"METRIC:drafts:{metrics['drafts']}")
states = ",".join(f"{k}={v}" for k, v in sorted(metrics['draft_states'].items())) or "none"
print(f"METRIC:draft_states:{states}")
last = metrics.get("last_event") or {}
if last:
    print(f"LAST_EVENT:{last.get('event')}:{last.get('ts')}")
PY
)
while IFS= read -r line; do
    case "$line" in
        ENABLED:True) ok "email enabled" ;;
        ENABLED:False) info "email disabled" ;;
        CRED:*:ok) key="${line#CRED:}"; key="${key%:ok}"; ok "email $key set" ;;
        CRED:*:missing) key="${line#CRED:}"; key="${key%:missing}"; warn "email $key missing" ;;
        METRIC:last_uid:*) info "email last_uid: ${line#METRIC:last_uid:}" ;;
        METRIC:pending:0) ok "email pending inbound: 0" ;;
        METRIC:pending:*) warn "email pending inbound: ${line#METRIC:pending:}" ;;
        METRIC:drafts:0) ok "email drafts: 0" ;;
        METRIC:drafts:*) warn "email drafts: ${line#METRIC:drafts:}" ;;
        METRIC:draft_states:*) info "email draft states: ${line#METRIC:draft_states:}" ;;
        LAST_EVENT:*) info "email last event: ${line#LAST_EVENT:}" ;;
        Traceback*|ERROR:*) warn "email check failed: $line" ;;
    esac
done <<<"$EMAIL_CHECK"

# --- Workers ---

section "Workers"

STATE_DIR="$INSTANCE_DIR/state"
if [[ -d "$STATE_DIR" ]]; then
    if [[ -w "$STATE_DIR" ]]; then
        ok "state/ present and writable"
    else
        fail "state/ not writable"
    fi
else
    if [[ "$FIX" == 1 ]]; then
        mkdir -p "$STATE_DIR"
        fixed "state/ created"
    else
        info "state/ not yet created (first spawn creates it)"
    fi
fi

WORKER_DB="$STATE_DIR/workers.db"
if [[ -f "$WORKER_DB" ]]; then
    SIZE=$(du -h "$WORKER_DB" | awk '{print $1}')
    ok "state/workers.db present ($SIZE)"

    # Count orphan candidates — non-terminal rows with dead/missing pid.
    ORPHAN_CHECK=$("$JC_PYTHON" - "$WORKER_DB" <<'PY' 2>/dev/null
import os, sqlite3, sys
try:
    conn = sqlite3.connect(sys.argv[1])
    rows = conn.execute(
        "SELECT id, pid FROM workers WHERE status IN ('queued','running','need_input')"
    ).fetchall()
    dead = 0
    for _id, pid in rows:
        if pid is None:
            dead += 1; continue
        try:
            os.kill(pid, 0)
        except ProcessLookupError:
            dead += 1
        except PermissionError:
            pass
    print(f"{dead}/{len(rows)}")
except Exception:
    print("?/?")
PY
)
    case "$ORPHAN_CHECK" in
        0/*) ok "no orphan worker rows ($ORPHAN_CHECK non-terminal)" ;;
        ?/?) info "worker DB unreadable" ;;
        */*) DEAD="${ORPHAN_CHECK%/*}"; TOT="${ORPHAN_CHECK#*/}"
             warn "$DEAD/$TOT non-terminal worker rows look orphaned — run: jc workers reconcile" ;;
    esac
else
    info "state/workers.db not yet created (first spawn creates it)"
fi

# --- Summary ---

echo ""
if [[ $FAIL -eq 0 ]]; then
    printf '%sAll critical checks passed.%s\n' "$GRN" "$RST"
    exit 0
else
    printf '%s%d critical issue(s) found.%s\n' "$RED" "$FAIL" "$RST"
    exit 1
fi
