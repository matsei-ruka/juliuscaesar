#!/usr/bin/env bash
# jc-watchdog — supervise a JuliusCaesar instance's live claude session.
#
# Subcommands:
#   tick        Run one supervisor tick (for cron).
#   install     Install cron entries (@reboot + */2 * * * *) for this instance.
#   uninstall   Remove this instance's cron entries.
#   status      Print current state + tail of log.
#   test-notify Send a manual Telegram ping to verify creds.
#
# Instance dir resolution (same as other jc-* binaries):
#   --instance-dir <path>  →  $JC_INSTANCE_DIR  →  walk up for .jc  →  cwd

set -uo pipefail

HERE="$(cd "$(dirname "$(readlink -f "$0" 2>/dev/null || echo "$0")")" && pwd)"
LIB_DIR="$(cd "$HERE/../lib" && pwd)"
WATCHDOG_SH="$LIB_DIR/watchdog/watchdog.sh"

shell_quote() {
    local value="$1"
    printf "'"
    printf '%s' "$value" | sed "s/'/'\\\\''/g"
    printf "'"
}

load_env_file() {
    local file="$1"
    local line key value
    [[ -f "$file" ]] || return 0
    while IFS= read -r line || [[ -n "$line" ]]; do
        line="${line%$'\r'}"
        [[ -z "${line//[[:space:]]/}" || "$line" =~ ^[[:space:]]*# ]] && continue
        [[ "$line" == *"="* ]] || continue
        key="${line%%=*}"
        value="${line#*=}"
        key="${key#"${key%%[![:space:]]*}"}"
        key="${key%"${key##*[![:space:]]}"}"
        case "$key" in
            TELEGRAM_BOT_TOKEN|TELEGRAM_CHAT_ID) ;;
            *) continue ;;
        esac
        value="${value#"${value%%[![:space:]]*}"}"
        if [[ "$value" == \'* && "$value" == *\' ]]; then
            value="${value:1:${#value}-2}"
        elif [[ "$value" == \"* && "$value" == *\" ]]; then
            value="${value:1:${#value}-2}"
        fi
        export "$key=$value"
    done < "$file"
}

# --- Instance dir resolution ---
resolve_instance_dir() {
    local arg="${1:-}"
    if [[ -n "$arg" ]]; then
        [[ -d "$arg" ]] || { echo "--instance-dir does not exist: $arg" >&2; exit 2; }
        (cd "$arg" && pwd)
        return 0
    fi
    if [[ -n "${JC_INSTANCE_DIR:-}" && -d "$JC_INSTANCE_DIR" ]]; then
        (cd "$JC_INSTANCE_DIR" && pwd)
        return 0
    fi
    local cur
    cur="$(pwd)"
    while :; do
        [[ -f "$cur/.jc" ]] && { echo "$cur"; return 0; }
        local parent
        parent="$(dirname "$cur")"
        [[ "$parent" == "$cur" ]] && break
        cur="$parent"
    done
    if [[ -d "$(pwd)/ops" ]]; then
        pwd; return 0
    fi
    echo "Could not resolve instance dir. Use --instance-dir, set JC_INSTANCE_DIR, or create a .jc marker." >&2
    exit 2
}

# Parse --instance-dir
INSTANCE_DIR_ARG=""
REST=()
while (( $# )); do
    case "$1" in
        --instance-dir) INSTANCE_DIR_ARG="$2"; shift 2 ;;
        --instance-dir=*) INSTANCE_DIR_ARG="${1#*=}"; shift ;;
        *) REST+=("$1"); shift ;;
    esac
done
set -- "${REST[@]:+${REST[@]}}"

SUBCMD="${1:-}"
shift || true
INSTANCE_DIR="$(resolve_instance_dir "$INSTANCE_DIR_ARG")"

PYTHON_BIN="${PYTHON_BIN:-python3}"
WATCHDOG_YAML="$INSTANCE_DIR/ops/watchdog.yaml"

run_v2_cli() {
    JC_LIB_DIR="$LIB_DIR" PYTHONPATH="$LIB_DIR${PYTHONPATH:+:$PYTHONPATH}" \
        "$PYTHON_BIN" -m watchdog.cli --instance-dir "$INSTANCE_DIR" "$@"
}

case "$SUBCMD" in
    tick|"")
        if [[ -f "$WATCHDOG_YAML" ]]; then
            JC_LIB_DIR="$LIB_DIR" PYTHONPATH="$LIB_DIR${PYTHONPATH:+:$PYTHONPATH}" \
                exec "$PYTHON_BIN" -m watchdog.supervisor "$INSTANCE_DIR"
        fi
        exec bash "$WATCHDOG_SH" "$INSTANCE_DIR"
        ;;

    status-v2)
        run_v2_cli status "$@"
        exit $?
        ;;

    tail|reset|reload|migrate)
        run_v2_cli "$SUBCMD" "$@"
        exit $?
        ;;

    install)
        # Determine screen name (same logic as watchdog.sh)
        SCREEN_NAME="jc-$(basename "$INSTANCE_DIR")"
        if [[ -f "$INSTANCE_DIR/ops/watchdog.conf" ]]; then
            # shellcheck disable=SC1091
            source "$INSTANCE_DIR/ops/watchdog.conf"
        fi
        JC_BIN="$HOME/.local/bin/jc-watchdog"
        [[ -x "$JC_BIN" ]] || { echo "jc-watchdog not installed at $JC_BIN. Run juliuscaesar install.sh first." >&2; exit 1; }

        TAG="# jc-watchdog for $INSTANCE_DIR"
        ENTRY_REBOOT="@reboot $(shell_quote "$JC_BIN") tick --instance-dir $(shell_quote "$INSTANCE_DIR")  $TAG"
        ENTRY_TICK="*/2 * * * * $(shell_quote "$JC_BIN") tick --instance-dir $(shell_quote "$INSTANCE_DIR")  $TAG"

        # Build new crontab in a tempfile — crontab(1) refuses stdin that
        # lacks a trailing newline, and command-substitution strips them.
        TMP_CRON="$(mktemp)"
        trap 'rm -f "$TMP_CRON"' EXIT
        crontab -l 2>/dev/null | grep -vF "$TAG" > "$TMP_CRON" || true
        {
            echo ""
            echo "$ENTRY_REBOOT"
            echo "$ENTRY_TICK"
        } >> "$TMP_CRON"
        crontab "$TMP_CRON"
        echo "Installed cron entries for $INSTANCE_DIR (screen: $SCREEN_NAME)"
        crontab -l | grep -F "$TAG"
        ;;

    uninstall)
        TAG="# jc-watchdog for $INSTANCE_DIR"
        TMP_CRON="$(mktemp)"
        trap 'rm -f "$TMP_CRON"' EXIT
        crontab -l 2>/dev/null | grep -vF "$TAG" > "$TMP_CRON" || true
        crontab "$TMP_CRON"
        echo "Removed cron entries for $INSTANCE_DIR"
        ;;

    status)
        SCREEN_NAME="jc-$(basename "$INSTANCE_DIR")"
        if [[ -f "$INSTANCE_DIR/ops/watchdog.conf" ]]; then
            # shellcheck disable=SC1091
            source "$INSTANCE_DIR/ops/watchdog.conf"
        fi
        STATE_FILE="/tmp/jc-watchdog-${SCREEN_NAME}.state"
        LOG_FILE="/tmp/jc-watchdog-${SCREEN_NAME}.log"
        echo "instance:     $INSTANCE_DIR"
        echo "runtime:      ${RUNTIME_MODE:-legacy-claude}"
        echo "screen name:  $SCREEN_NAME"
        echo "session id:   ${SESSION_ID:-<none>}"
        echo "state:        $([[ -f "$STATE_FILE" ]] && cat "$STATE_FILE" || echo unknown)"
        echo "cron entries:"
        crontab -l 2>/dev/null | grep -F "jc-watchdog for $INSTANCE_DIR" || echo "  (none installed)"
        echo ""
        echo "last 15 log lines:"
        [[ -f "$LOG_FILE" ]] && tail -15 "$LOG_FILE" || echo "  (no log)"
        ;;

    test-notify)
        if [[ -f "$INSTANCE_DIR/.env" ]]; then
            load_env_file "$INSTANCE_DIR/.env"
        fi
        : "${TELEGRAM_BOT_TOKEN:?TELEGRAM_BOT_TOKEN not set in $INSTANCE_DIR/.env}"
        : "${TELEGRAM_CHAT_ID:?TELEGRAM_CHAT_ID not set in $INSTANCE_DIR/.env}"
        # Route through the canonical sender so test-notify exercises the
        # same MarkdownV2 path that production traffic does — easier to
        # spot escaper bugs early.
        SENDER="$(dirname "$0")/../lib/heartbeat/lib/send_telegram.sh"
        if [[ ! -x "$SENDER" ]]; then
            SENDER="$(realpath "$(dirname "$0")/..")/lib/heartbeat/lib/send_telegram.sh"
        fi
        if [[ -x "$SENDER" ]]; then
            JC_INSTANCE_DIR="$INSTANCE_DIR" \
            printf 'jc-watchdog test-notify: %s' "$(date +'%FT%T%z')" \
                | JC_INSTANCE_DIR="$INSTANCE_DIR" "$SENDER"
        else
            echo "jc-watchdog: send_telegram.sh not found at $SENDER" >&2
            exit 1
        fi
        ;;

    -h|--help|help)
        cat <<'EOF'
jc-watchdog — supervise a JuliusCaesar instance's live claude session.

Usage:
  jc-watchdog [--instance-dir <path>] <subcommand>

Subcommands:
  tick          Run one supervisor tick (intended for cron).
  install       Install @reboot + */2 cron entries for this instance.
  uninstall     Remove this instance's cron entries.
  status        Show legacy state, cron entries, recent log.
  status-v2     Show v2 child status table (uses ops/watchdog.yaml).
  tail <child>  Tail a v2 child's log file.
  reset <child> Clear alert mode + restart counters (v2).
  reload        Re-read ops/watchdog.yaml and run one tick (v2).
  migrate       Generate ops/watchdog.yaml from ops/watchdog.conf.
  test-notify   Send a Telegram message to validate credentials.
EOF
        ;;

    *)
        echo "Unknown subcommand: $SUBCMD (try --help)" >&2
        exit 2
        ;;
esac
