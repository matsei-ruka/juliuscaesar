#!/usr/bin/env python3
"""jc-self-model — autonomous self-model loop for a persona instance.

Reads `state/transcripts/` + `memory/L1/HOT.md`, runs detectors, generates
LLM-backed proposals targeting JOURNAL.md / RULES.md / IDENTITY.md, stages
them for review. Constitutional invariants (frozen sections marked
<!-- IMMUTABILE --> + the registry in lib/self_model/frozen_sections.py)
are guarded at every layer: pre-LLM signal filter, post-LLM proposal filter,
apply-time HTML marker re-check, and a DKIM-email approval gate for any
modification to RULES/IDENTITY.

Subcommands (delegated to lib/self_model/cli.py):
  run        Execute one detection + proposal cycle.
  status     Show pending / applied / rejected counts.
  list       List proposals (filter by --state, --id).
  approve    Apply a proposal (DKIM gate enforced for non-JOURNAL targets).
  reject     Reject a proposal; record reason; optionally mark
             --ignore-as-signal to suppress the pattern in future cycles.
  history    Show applied + rejected lists.

Instance dir resolution: same as other jc-* binaries — explicit
--instance-dir, then $JC_INSTANCE_DIR, then walk up for `.jc` marker, then
cwd.

Configuration: `<instance>/ops/self_model.yaml`. Disabled by default; safe
to install. See `lib/self_model/conf.py` for the schema and defaults.
"""

from __future__ import annotations

import sys
from pathlib import Path

# Allow running directly from a clone without install.
_HERE = Path(__file__).resolve().parent
_LIB = _HERE.parent / "lib"
if _LIB.exists() and str(_LIB) not in sys.path:
    sys.path.insert(0, str(_LIB))

from self_model.cli import main  # type: ignore  # noqa: E402


if __name__ == "__main__":
    sys.exit(main())
