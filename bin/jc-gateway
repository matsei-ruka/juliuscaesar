#!/usr/bin/env python3
"""jc-gateway - gateway queue foundation for JuliusCaesar.

This first slice intentionally implements the durable queue and inspection
surface before channel adapters and brain invocation land.
"""

from __future__ import annotations

import argparse
import json
import os
import sys
from pathlib import Path


_HERE = Path(__file__).resolve().parent
_LIB = _HERE.parent / "lib"
if _LIB.exists() and str(_LIB) not in sys.path:
    sys.path.insert(0, str(_LIB))

from gateway import queue  # type: ignore  # noqa: E402


def resolve_instance_dir(arg: str | None) -> Path:
    if arg:
        p = Path(arg).expanduser().resolve()
        if not p.exists():
            raise SystemExit(f"--instance-dir does not exist: {p}")
        return p
    env = os.environ.get("JC_INSTANCE_DIR")
    if env:
        p = Path(env).expanduser().resolve()
        if not p.exists():
            raise SystemExit(f"JC_INSTANCE_DIR does not exist: {p}")
        return p
    cur = Path.cwd().resolve()
    while True:
        if (cur / ".jc").exists():
            return cur
        if cur.parent == cur:
            break
        cur = cur.parent
    cwd = Path.cwd().resolve()
    if (cwd / "memory").exists():
        return cwd
    raise SystemExit(
        "Could not resolve instance dir. Use --instance-dir, set JC_INSTANCE_DIR, "
        "or run from a directory containing memory/ or a .jc marker."
    )


def print_json(data: object) -> None:
    print(json.dumps(data, indent=2, sort_keys=True))


def parse_meta(raw: str | None) -> dict | None:
    if raw in (None, ""):
        return None
    try:
        data = json.loads(raw)
    except json.JSONDecodeError as exc:
        raise SystemExit(f"--meta must be valid JSON: {exc}") from exc
    if not isinstance(data, dict):
        raise SystemExit("--meta must decode to a JSON object")
    return data


def read_text_arg(value: str | None) -> str:
    if value in (None, "-"):
        return sys.stdin.read()
    return value


def cmd_init(args: argparse.Namespace) -> int:
    instance = resolve_instance_dir(args.instance_dir)
    conn = queue.connect(instance)
    conn.close()
    print(f"gateway queue initialized: {queue.queue_path(instance)}")
    return 0


def cmd_status(args: argparse.Namespace) -> int:
    instance = resolve_instance_dir(args.instance_dir)
    conn = queue.connect(instance)
    counts = queue.counts(conn)
    conn.close()
    print(f"instance: {instance}")
    print(f"queue:    {queue.queue_path(instance)}")
    if counts:
        for status in sorted(counts):
            print(f"{status}: {counts[status]}")
    else:
        print("events:   0")
    return 0


def cmd_enqueue(args: argparse.Namespace) -> int:
    instance = resolve_instance_dir(args.instance_dir)
    conn = queue.connect(instance)
    event, inserted = queue.enqueue(
        conn,
        source=args.source,
        source_message_id=args.source_message_id,
        user_id=args.user_id,
        conversation_id=args.conversation_id,
        content=read_text_arg(args.content),
        meta=parse_meta(args.meta),
    )
    conn.close()
    data = event.to_dict()
    data["inserted"] = inserted
    print_json(data)
    return 0


def cmd_claim(args: argparse.Namespace) -> int:
    instance = resolve_instance_dir(args.instance_dir)
    conn = queue.connect(instance)
    event = queue.claim_next(conn, worker_id=args.worker_id, lease_seconds=args.lease_seconds)
    conn.close()
    if event is None:
        print("no ready events")
        return 1
    print_json(event.to_dict())
    return 0


def cmd_complete(args: argparse.Namespace) -> int:
    instance = resolve_instance_dir(args.instance_dir)
    conn = queue.connect(instance)
    event = queue.complete(conn, args.event_id, response=read_text_arg(args.response))
    conn.close()
    print_json(event.to_dict())
    return 0


def cmd_fail(args: argparse.Namespace) -> int:
    instance = resolve_instance_dir(args.instance_dir)
    conn = queue.connect(instance)
    event = queue.fail(conn, args.event_id, error=args.error, max_retries=args.max_retries)
    conn.close()
    print_json(event.to_dict())
    return 0


def cmd_list(args: argparse.Namespace) -> int:
    instance = resolve_instance_dir(args.instance_dir)
    conn = queue.connect(instance)
    events = queue.recent(conn, limit=args.limit)
    conn.close()
    if args.json:
        print_json([event.to_dict() for event in events])
        return 0
    for event in events:
        content = event.content.replace("\n", " ")
        if len(content) > 80:
            content = content[:77] + "..."
        print(f"{event.id:>4} {event.status:<8} {event.source:<12} {event.received_at} {content}")
    return 0


def cmd_work_once(args: argparse.Namespace) -> int:
    instance = resolve_instance_dir(args.instance_dir)
    conn = queue.connect(instance)
    event = queue.claim_next(conn, worker_id=args.worker_id, lease_seconds=args.lease_seconds)
    if event is None:
        conn.close()
        print("no ready events")
        return 1
    if args.mode == "echo":
        response = event.content
    else:
        conn.close()
        raise SystemExit(f"unsupported work mode: {args.mode}")
    event = queue.complete(conn, event.id, response=response)
    conn.close()
    print_json(event.to_dict())
    return 0


def build_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(prog="jc-gateway")
    p.add_argument("--instance-dir")
    sub = p.add_subparsers(dest="cmd", required=True)

    pi = sub.add_parser("init", help="Create or migrate the gateway queue database")
    pi.set_defaults(func=cmd_init)

    ps = sub.add_parser("status", help="Show queue path and event counts")
    ps.set_defaults(func=cmd_status)

    pe = sub.add_parser("enqueue", help="Enqueue a gateway event")
    pe.add_argument("content", nargs="?", help="Event content. Omit or use '-' to read stdin.")
    pe.add_argument("--source", default="manual")
    pe.add_argument("--source-message-id")
    pe.add_argument("--user-id")
    pe.add_argument("--conversation-id")
    pe.add_argument("--meta", help="JSON object")
    pe.set_defaults(func=cmd_enqueue)

    pc = sub.add_parser("claim", help="Claim one ready event")
    pc.add_argument("--worker-id", default=f"manual-{os.getpid()}")
    pc.add_argument("--lease-seconds", type=int, default=300)
    pc.set_defaults(func=cmd_claim)

    pd = sub.add_parser("complete", help="Mark an event done")
    pd.add_argument("event_id", type=int)
    pd.add_argument("--response", default="-", help="Response text. Default reads stdin.")
    pd.set_defaults(func=cmd_complete)

    pf = sub.add_parser("fail", help="Mark an event failed or queued for retry")
    pf.add_argument("event_id", type=int)
    pf.add_argument("--error", required=True)
    pf.add_argument("--max-retries", type=int, default=3)
    pf.set_defaults(func=cmd_fail)

    pl = sub.add_parser("list", help="List recent events")
    pl.add_argument("--limit", type=int, default=20)
    pl.add_argument("--json", action="store_true")
    pl.set_defaults(func=cmd_list)

    pw = sub.add_parser("work-once", help="Claim and process one event with a test worker")
    pw.add_argument("--worker-id", default=f"worker-{os.getpid()}")
    pw.add_argument("--lease-seconds", type=int, default=300)
    pw.add_argument("--mode", choices=["echo"], default="echo")
    pw.set_defaults(func=cmd_work_once)

    return p


def main() -> int:
    args = build_parser().parse_args()
    return args.func(args)


if __name__ == "__main__":
    raise SystemExit(main())
