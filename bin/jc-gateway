#!/usr/bin/env python3
"""jc-gateway - production channel/brain gateway for JuliusCaesar."""

from __future__ import annotations

import argparse
import json
import os
import signal
import subprocess
import sys
import time
from datetime import datetime, timezone
from pathlib import Path


_HERE = Path(__file__).resolve().parent
_LIB = _HERE.parent / "lib"
if _LIB.exists() and str(_LIB) not in sys.path:
    sys.path.insert(0, str(_LIB))

from gateway import queue  # type: ignore  # noqa: E402
from gateway.config import ConfigError, config_path, load_config, validate_config  # type: ignore  # noqa: E402
from gateway.runtime import GatewayRuntime  # type: ignore  # noqa: E402
from jc_paths import InstanceResolutionError, resolve_instance_dir as _resolve_instance_dir  # type: ignore  # noqa: E402


RUNNING = True


def resolve_instance_dir(arg: str | None) -> Path:
    try:
        return _resolve_instance_dir(arg, fallback_markers=("memory",))
    except InstanceResolutionError as exc:
        raise SystemExit(str(exc)) from exc


def print_json(data: object) -> None:
    print(json.dumps(data, indent=2, sort_keys=True))


def parse_meta(raw: str | None) -> dict | None:
    if raw in (None, ""):
        return None
    try:
        data = json.loads(raw)
    except json.JSONDecodeError as exc:
        raise SystemExit(f"--meta must be valid JSON: {exc}") from exc
    if not isinstance(data, dict):
        raise SystemExit("--meta must decode to a JSON object")
    return data


def read_text_arg(value: str | None) -> str:
    if value in (None, "-"):
        return sys.stdin.read()
    return value


def pid_path(instance_dir: Path) -> Path:
    return queue.queue_dir(instance_dir) / "jc-gateway.pid"


def log_path(instance_dir: Path) -> Path:
    return queue.queue_dir(instance_dir) / "gateway.log"


def now_line() -> str:
    return datetime.now(timezone.utc).isoformat(timespec="seconds").replace("+00:00", "Z")


def log_line(instance_dir: Path, message: str) -> None:
    path = log_path(instance_dir)
    path.parent.mkdir(parents=True, exist_ok=True)
    with path.open("a", encoding="utf-8") as handle:
        handle.write(f"[{now_line()}] {message}\n")


def read_pid(instance_dir: Path) -> int | None:
    try:
        raw = pid_path(instance_dir).read_text(encoding="utf-8").strip()
    except FileNotFoundError:
        return None
    if not raw:
        return None
    try:
        return int(raw)
    except ValueError:
        return None


def pid_alive(pid: int | None) -> bool:
    if pid is None:
        return False
    try:
        os.kill(pid, 0)
    except PermissionError:
        return True
    except OSError:
        return False
    return True


def remove_stale_pid(instance_dir: Path) -> None:
    pid = read_pid(instance_dir)
    if pid is None or not pid_alive(pid):
        pid_path(instance_dir).unlink(missing_ok=True)


RELOAD_REQUESTED = False


def install_signal_handlers(*, on_reload=None) -> None:
    def _handle(_signum: int, _frame: object) -> None:
        global RUNNING
        RUNNING = False

    def _hup(_signum: int, _frame: object) -> None:
        global RELOAD_REQUESTED
        RELOAD_REQUESTED = True

    signal.signal(signal.SIGTERM, _handle)
    signal.signal(signal.SIGINT, _handle)
    signal.signal(signal.SIGHUP, _hup)


def cmd_init(args: argparse.Namespace) -> int:
    instance = resolve_instance_dir(args.instance_dir)
    conn = queue.connect(instance)
    conn.close()
    print(f"gateway queue initialized: {queue.queue_path(instance)}")
    return 0


def cmd_status(args: argparse.Namespace) -> int:
    instance = resolve_instance_dir(args.instance_dir)
    conn = queue.connect(instance)
    counts = queue.counts(conn)
    conn.close()
    pid = read_pid(instance)
    print(f"instance: {instance}")
    print(f"queue:    {queue.queue_path(instance)}")
    print(f"config:   {config_path(instance)}")
    print(f"pidfile:  {pid_path(instance)}")
    print(f"log:      {log_path(instance)}")
    if pid_alive(pid):
        print(f"daemon:   running (pid {pid})")
    elif pid is not None:
        print(f"daemon:   stale pidfile (pid {pid})")
    else:
        print("daemon:   stopped")
    if counts:
        for status in sorted(counts):
            print(f"{status}: {counts[status]}")
    else:
        print("events:   0")
    return 0


def cmd_run(args: argparse.Namespace) -> int:
    instance = resolve_instance_dir(args.instance_dir)
    validate_config(instance)
    conn = queue.connect(instance)
    conn.close()
    queue.queue_dir(instance).mkdir(parents=True, exist_ok=True)
    existing = read_pid(instance)
    if pid_alive(existing) and existing != os.getpid():
        raise SystemExit(f"gateway already running (pid {existing})")
    remove_stale_pid(instance)
    pid_path(instance).write_text(f"{os.getpid()}\n", encoding="utf-8")
    install_signal_handlers()
    log_line(instance, f"gateway daemon started pid={os.getpid()}")
    runtime = GatewayRuntime(instance, log_path=log_path(instance), stop_requested=lambda: not RUNNING)
    runtime.start_channels()
    runtime.start_heartbeat()
    try:
        global RELOAD_REQUESTED
        while RUNNING:
            if RELOAD_REQUESTED:
                RELOAD_REQUESTED = False
                try:
                    runtime.reload_config()
                    log_line(instance, "gateway config reloaded")
                except Exception as exc:  # noqa: BLE001
                    log_line(instance, f"reload failed: {exc}")
            if not pid_path(instance).exists():
                pid_path(instance).write_text(f"{os.getpid()}\n", encoding="utf-8")
            conn = queue.connect(instance)
            try:
                requeued = queue.requeue_expired(conn)
                conn.commit()
            finally:
                conn.close()
            if requeued:
                log_line(
                    instance,
                    f"requeued expired events count={len(requeued)} ids={requeued}",
                )
            runtime.dispatch_once()
            time.sleep(args.interval_seconds)
    finally:
        runtime.close()
        pid_path(instance).unlink(missing_ok=True)
        log_line(instance, "gateway daemon stopped")
    return 0


def cmd_start(args: argparse.Namespace) -> int:
    instance = resolve_instance_dir(args.instance_dir)
    validate_config(instance)
    conn = queue.connect(instance)
    conn.close()
    existing = read_pid(instance)
    if pid_alive(existing):
        print(f"gateway already running (pid {existing})")
        return 0
    remove_stale_pid(instance)
    queue.queue_dir(instance).mkdir(parents=True, exist_ok=True)
    log_handle = log_path(instance).open("a", encoding="utf-8")
    cmd = [
        sys.executable,
        str(Path(__file__).resolve()),
        "--instance-dir",
        str(instance),
        "run",
        "--interval-seconds",
        str(args.interval_seconds),
    ]
    proc = subprocess.Popen(
        cmd,
        cwd=str(instance),
        stdin=subprocess.DEVNULL,
        stdout=log_handle,
        stderr=log_handle,
        start_new_session=True,
    )
    log_handle.close()
    pid_path(instance).write_text(f"{proc.pid}\n", encoding="utf-8")
    log_line(instance, f"gateway daemon launch requested pid={proc.pid}")
    print(f"gateway started (pid {proc.pid})")
    return 0


def cmd_stop(args: argparse.Namespace) -> int:
    instance = resolve_instance_dir(args.instance_dir)
    pid = read_pid(instance)
    if not pid_alive(pid):
        remove_stale_pid(instance)
        print("gateway already stopped")
        return 0
    assert pid is not None
    os.kill(pid, signal.SIGTERM)
    deadline = time.monotonic() + args.timeout_seconds
    while time.monotonic() < deadline:
        if not pid_alive(pid):
            remove_stale_pid(instance)
            print(f"gateway stopped (pid {pid})")
            return 0
        time.sleep(0.2)
    if args.kill:
        os.kill(pid, signal.SIGKILL)
        remove_stale_pid(instance)
        print(f"gateway killed (pid {pid})")
        return 0
    raise SystemExit(f"gateway did not stop within {args.timeout_seconds}s (pid {pid})")


def cmd_restart(args: argparse.Namespace) -> int:
    stop_args = argparse.Namespace(
        instance_dir=args.instance_dir,
        timeout_seconds=args.timeout_seconds,
        kill=args.kill,
    )
    cmd_stop(stop_args)
    start_args = argparse.Namespace(
        instance_dir=args.instance_dir,
        interval_seconds=args.interval_seconds,
    )
    return cmd_start(start_args)


def cmd_tail(args: argparse.Namespace) -> int:
    instance = resolve_instance_dir(args.instance_dir)
    path = log_path(instance)
    if not path.exists():
        print(f"log does not exist yet: {path}")
        return 1
    lines = path.read_text(encoding="utf-8", errors="replace").splitlines()
    for line in lines[-args.lines :]:
        print(line)
    if not args.follow:
        return 0
    with path.open("r", encoding="utf-8", errors="replace") as handle:
        handle.seek(0, os.SEEK_END)
        while True:
            line = handle.readline()
            if line:
                print(line, end="")
            else:
                time.sleep(0.5)


def cmd_logs_alias(args: argparse.Namespace) -> int:
    """Wrapper that selects between filter mode and plain tail."""
    if args.since or args.cls or args.brain or args.source or args.limit:
        return cmd_logs_filter(args)
    return cmd_tail(args)


def cmd_logs(args: argparse.Namespace) -> int:
    return cmd_tail(args)


def cmd_enqueue(args: argparse.Namespace) -> int:
    instance = resolve_instance_dir(args.instance_dir)
    conn = queue.connect(instance)
    event, inserted = queue.enqueue(
        conn,
        source=args.source,
        source_message_id=args.source_message_id,
        user_id=args.user_id,
        conversation_id=args.conversation_id,
        content=read_text_arg(args.content),
        meta=parse_meta(args.meta),
    )
    conn.close()
    data = event.to_dict()
    data["inserted"] = inserted
    print_json(data)
    return 0


def cmd_claim(args: argparse.Namespace) -> int:
    instance = resolve_instance_dir(args.instance_dir)
    conn = queue.connect(instance)
    event = queue.claim_next(conn, worker_id=args.worker_id, lease_seconds=args.lease_seconds)
    conn.close()
    if event is None:
        print("no ready events")
        return 1
    print_json(event.to_dict())
    return 0


def cmd_complete(args: argparse.Namespace) -> int:
    instance = resolve_instance_dir(args.instance_dir)
    conn = queue.connect(instance)
    event = queue.complete(conn, args.event_id, response=read_text_arg(args.response))
    conn.close()
    print_json(event.to_dict())
    return 0


def cmd_fail(args: argparse.Namespace) -> int:
    instance = resolve_instance_dir(args.instance_dir)
    conn = queue.connect(instance)
    event = queue.fail(conn, args.event_id, error=args.error, max_retries=args.max_retries)
    conn.close()
    print_json(event.to_dict())
    return 0


def cmd_list(args: argparse.Namespace) -> int:
    instance = resolve_instance_dir(args.instance_dir)
    conn = queue.connect(instance)
    events = queue.recent(conn, limit=args.limit)
    conn.close()
    if args.json:
        print_json([event.to_dict() for event in events])
        return 0
    for event in events:
        content = event.content.replace("\n", " ")
        if len(content) > 80:
            content = content[:77] + "..."
        print(f"{event.id:>4} {event.status:<8} {event.source:<12} {event.received_at} {content}")
    return 0


def cmd_events(args: argparse.Namespace) -> int:
    return cmd_list(args)


def cmd_retry(args: argparse.Namespace) -> int:
    instance = resolve_instance_dir(args.instance_dir)
    conn = queue.connect(instance)
    event = queue.retry_now(conn, args.event_id)
    conn.close()
    print_json(event.to_dict())
    return 0


def cmd_config(args: argparse.Namespace) -> int:
    instance = resolve_instance_dir(args.instance_dir)
    if args.json:
        cfg = load_config(instance)
        print_json(
            {
                "path": str(config_path(instance)),
                "default_brain": cfg.default_brain,
                "default_model": cfg.default_model,
                "gateway": {
                    "poll_interval_seconds": cfg.poll_interval_seconds,
                    "lease_seconds": cfg.lease_seconds,
                    "max_retries": cfg.max_retries,
                    "adapter_timeout_seconds": cfg.adapter_timeout_seconds,
                },
                "channels": {
                    name: {
                        "enabled": ch.enabled,
                        "token_env": ch.token_env,
                        "app_token_env": ch.app_token_env,
                        "bot_token_env": ch.bot_token_env,
                        "chat_ids": list(ch.chat_ids),
                        "brain": ch.brain,
                        "model": ch.model,
                    }
                    for name, ch in cfg.channels.items()
                },
            }
        )
    else:
        path = config_path(instance)
        if path.exists():
            print(path.read_text(encoding="utf-8"), end="")
        else:
            print(f"gateway config not found: {path}")
            return 1
    return 0


def cmd_work_once(args: argparse.Namespace) -> int:
    instance = resolve_instance_dir(args.instance_dir)
    conn = queue.connect(instance)
    event = queue.claim_next(conn, worker_id=args.worker_id, lease_seconds=args.lease_seconds)
    if event is None:
        conn.close()
        print("no ready events")
        return 1
    if args.mode == "echo":
        response = event.content
    else:
        conn.close()
        raise SystemExit(f"unsupported work mode: {args.mode}")
    event = queue.complete(conn, event.id, response=response)
    conn.close()
    print_json(event.to_dict())
    return 0


def _parse_since(value: str) -> float:
    if not value:
        return 0.0
    suffix = value[-1]
    try:
        n = int(value[:-1])
    except ValueError:
        return 0.0
    multipliers = {"s": 1, "m": 60, "h": 3600, "d": 86400}
    return time.time() - n * multipliers.get(suffix, 60)


def cmd_logs_filter(args: argparse.Namespace) -> int:
    instance = resolve_instance_dir(args.instance_dir)
    path = log_path(instance)
    if not path.exists():
        print(f"log does not exist yet: {path}")
        return 1
    cutoff = _parse_since(args.since) if args.since else 0.0
    matched = 0
    for raw in path.read_text(encoding="utf-8", errors="replace").splitlines():
        line = raw.strip()
        if not line.startswith("{"):
            continue
        try:
            payload = __import__("json").loads(line)
        except Exception:
            continue
        if cutoff:
            ts = payload.get("ts") or ""
            try:
                from datetime import datetime as _dt

                t = _dt.fromisoformat(ts.replace("Z", "+00:00")).timestamp()
                if t < cutoff:
                    continue
            except Exception:
                pass
        if args.cls and str(payload.get("class") or "") != args.cls:
            continue
        if args.brain and str(payload.get("brain") or "") != args.brain:
            continue
        if args.source and str(payload.get("source") or "") != args.source:
            continue
        print(line)
        matched += 1
        if args.limit and matched >= args.limit:
            break
    return 0


def cmd_metrics(args: argparse.Namespace) -> int:
    instance = resolve_instance_dir(args.instance_dir)
    from gateway.triage import MetricsRecorder

    recorder = MetricsRecorder(instance)
    summary = recorder.summary(hours=args.hours)
    if args.json:
        print_json(summary)
        return 0
    print(f"triage metrics since {summary['since']}")
    if not summary["by_class"]:
        print("(no observations)")
        return 0
    for row in summary["by_class"]:
        print(
            f"  {row['class']:<10} count={row['count']:<5} "
            f"avg_conf={row['avg_confidence']:.2f} "
            f"fallbacks={row['fallbacks']} overrides={row['overrides']}"
        )
    return 0


def cmd_reload(args: argparse.Namespace) -> int:
    instance = resolve_instance_dir(args.instance_dir)
    pid = read_pid(instance)
    if not pid_alive(pid):
        raise SystemExit("gateway daemon not running")
    os.kill(pid, signal.SIGHUP)
    print(f"sent SIGHUP to pid {pid}")
    return 0


def cmd_validate_config(args: argparse.Namespace) -> int:
    instance = resolve_instance_dir(args.instance_dir)
    try:
        validate_config(instance)
    except ConfigError as exc:
        print(f"gateway config invalid: {exc}", file=sys.stderr)
        return 1
    print(f"gateway config OK: {config_path(instance)}")
    return 0


def build_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(prog="jc-gateway")
    p.add_argument("--instance-dir")
    sub = p.add_subparsers(dest="cmd", required=True)

    pi = sub.add_parser("init", help="Create or migrate the gateway queue database")
    pi.set_defaults(func=cmd_init)

    ps = sub.add_parser("status", help="Show queue path and event counts")
    ps.set_defaults(func=cmd_status)

    pr = sub.add_parser("run", help="Run the gateway dispatcher in the foreground")
    pr.add_argument("--interval-seconds", type=float, default=1.0)
    pr.set_defaults(func=cmd_run)

    pstart = sub.add_parser("start", help="Start the gateway daemon")
    pstart.add_argument("--interval-seconds", type=float, default=1.0)
    pstart.set_defaults(func=cmd_start)

    pstop = sub.add_parser("stop", help="Stop the gateway daemon")
    pstop.add_argument("--timeout-seconds", type=float, default=10.0)
    pstop.add_argument("--kill", action="store_true", help="SIGKILL if SIGTERM timeout expires")
    pstop.set_defaults(func=cmd_stop)

    prestart = sub.add_parser("restart", help="Restart the gateway daemon")
    prestart.add_argument("--interval-seconds", type=float, default=5.0)
    prestart.add_argument("--timeout-seconds", type=float, default=10.0)
    prestart.add_argument("--kill", action="store_true", help="SIGKILL if SIGTERM timeout expires")
    prestart.set_defaults(func=cmd_restart)

    ptail = sub.add_parser("tail", help="Print gateway log tail")
    ptail.add_argument("-n", "--lines", type=int, default=40)
    ptail.add_argument("-f", "--follow", action="store_true")
    ptail.set_defaults(func=cmd_tail)

    plogs = sub.add_parser("logs", help="Filter the JSON gateway log")
    plogs.add_argument("-n", "--lines", type=int, default=80)
    plogs.add_argument("-f", "--follow", action="store_true")
    plogs.add_argument("--since", help="Time window e.g. 10m, 2h, 1d (filters JSON lines)")
    plogs.add_argument("--class", dest="cls", help="Filter by triage class (e.g. analysis)")
    plogs.add_argument("--brain", help="Filter by brain (e.g. claude:opus-4-7-1m)")
    plogs.add_argument("--source", help="Filter by source channel")
    plogs.add_argument("--limit", type=int, default=0, help="Stop after N matches (0=all)")
    plogs.set_defaults(func=cmd_logs_alias)

    pe = sub.add_parser("enqueue", help="Enqueue a gateway event")
    pe.add_argument("content", nargs="?", help="Event content. Omit or use '-' to read stdin.")
    pe.add_argument("--source", default="manual")
    pe.add_argument("--source-message-id")
    pe.add_argument("--user-id")
    pe.add_argument("--conversation-id")
    pe.add_argument("--meta", help="JSON object")
    pe.set_defaults(func=cmd_enqueue)

    pc = sub.add_parser("claim", help="Claim one ready event")
    pc.add_argument("--worker-id", default=f"manual-{os.getpid()}")
    pc.add_argument("--lease-seconds", type=int, default=300)
    pc.set_defaults(func=cmd_claim)

    pd = sub.add_parser("complete", help="Mark an event done")
    pd.add_argument("event_id", type=int)
    pd.add_argument("--response", default="-", help="Response text. Default reads stdin.")
    pd.set_defaults(func=cmd_complete)

    pf = sub.add_parser("fail", help="Mark an event failed or queued for retry")
    pf.add_argument("event_id", type=int)
    pf.add_argument("--error", required=True)
    pf.add_argument("--max-retries", type=int, default=3)
    pf.set_defaults(func=cmd_fail)

    pl = sub.add_parser("list", help="List recent events")
    pl.add_argument("--limit", type=int, default=20)
    pl.add_argument("--json", action="store_true")
    pl.set_defaults(func=cmd_list)

    pev = sub.add_parser("events", help="List recent events")
    pev.add_argument("--limit", type=int, default=20)
    pev.add_argument("--json", action="store_true")
    pev.set_defaults(func=cmd_events)

    pret = sub.add_parser("retry", help="Requeue an event immediately")
    pret.add_argument("event_id", type=int)
    pret.set_defaults(func=cmd_retry)

    pcfg = sub.add_parser("config", help="Show resolved gateway config")
    pcfg.add_argument("--json", action="store_true")
    pcfg.set_defaults(func=cmd_config)

    pvc = sub.add_parser("validate-config", help="Validate ops/gateway.yaml")
    pvc.set_defaults(func=cmd_validate_config)

    pw = sub.add_parser("work-once", help="Claim and process one event with a test worker")
    pw.add_argument("--worker-id", default=f"worker-{os.getpid()}")
    pw.add_argument("--lease-seconds", type=int, default=300)
    pw.add_argument("--mode", choices=["echo"], default="echo")
    pw.set_defaults(func=cmd_work_once)

    pmet = sub.add_parser("metrics", help="Print recent triage metrics")
    pmet.add_argument("--hours", type=int, default=24)
    pmet.add_argument("--json", action="store_true")
    pmet.set_defaults(func=cmd_metrics)

    pre = sub.add_parser("reload", help="SIGHUP the running daemon to reload config")
    pre.set_defaults(func=cmd_reload)

    return p


def main() -> int:
    args = build_parser().parse_args()
    return args.func(args)


if __name__ == "__main__":
    raise SystemExit(main())
