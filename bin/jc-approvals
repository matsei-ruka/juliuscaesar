#!/usr/bin/env python3
"""jc-approvals — unified local approval table CLI.

Subcommands:
  list           List approvals (default --status pending).
  show <id>      Show one approval (prefix match accepted).
  approve <id>   Approve a pending row (CLI gate blocks SENSITIVE rows).
  reject  <id>   Reject a pending row.
  expire  <id>   Force a pending row into the expired state.
  apply   <id>   Re-run the apply callback for an approved row.
  gc             Hard-delete terminal rows past the retention window.

Instance dir resolution: --instance-dir, $JC_INSTANCE_DIR, then cwd walk-up.
"""

from __future__ import annotations

import sys
from pathlib import Path

_HERE = Path(__file__).resolve().parent
_LIB = _HERE.parent / "lib"
if _LIB.exists() and str(_LIB) not in sys.path:
    sys.path.insert(0, str(_LIB))

from approvals.cli import main  # type: ignore  # noqa: E402


if __name__ == "__main__":
    sys.exit(main())
