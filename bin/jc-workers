#!/usr/bin/env python3
"""jc-workers — on-demand background agents for JuliusCaesar.

Subcommands (Sprint 1 — initial slice):
  spawn     Fork a detached worker that runs a brain adapter on a prompt.
  _run      (internal) The detached runner. Invoked by spawn via double-fork.
  list      Print workers table.
  show      Print one worker's full state.
  tail      `tail -f` a worker's log.

Future sprints add: cancel, gc, reconcile, timeout enforcement, notifications.

Instance dir resolution (same as jc-memory):
  1. --instance-dir <path> flag
  2. $JC_INSTANCE_DIR env var
  3. Walk up from cwd looking for a .jc marker file
  4. cwd if memory/ exists
"""

from __future__ import annotations

import argparse
import json
import os
import re
import shutil
import signal
import subprocess
import sys
import time
from datetime import datetime, timedelta, timezone
from pathlib import Path
from typing import Optional

# Allow running directly from a clone without install.
_HERE = Path(__file__).resolve().parent
_LIB = _HERE.parent / "lib"
if _LIB.exists() and str(_LIB) not in sys.path:
    sys.path.insert(0, str(_LIB))

from workers import (  # type: ignore  # noqa: E402
    Worker,
    connect,
    create,
    get,
    list_workers,
    mark_running,
    mark_terminal,
    worker_dir as _worker_dir,
    workers_dir,
)
from workers.db import _now_iso  # type: ignore  # noqa: E402


# Adapters + send_telegram live in the heartbeat lib (shared contract).
FRAMEWORK_ROOT = _HERE.parent
ADAPTERS_DIR = FRAMEWORK_ROOT / "lib" / "heartbeat" / "adapters"
SEND_TELEGRAM = FRAMEWORK_ROOT / "lib" / "heartbeat" / "lib" / "send_telegram.sh"


# --- Instance resolution (copied verbatim from jc-memory) --------------------


def resolve_instance_dir(arg: str | None) -> Path:
    if arg:
        p = Path(arg).expanduser().resolve()
        if not p.exists():
            raise SystemExit(f"--instance-dir does not exist: {p}")
        return p
    env = os.environ.get("JC_INSTANCE_DIR")
    if env:
        p = Path(env).expanduser().resolve()
        if not p.exists():
            raise SystemExit(f"JC_INSTANCE_DIR does not exist: {p}")
        return p
    cur = Path.cwd().resolve()
    while True:
        if (cur / ".jc").exists():
            return cur
        if cur.parent == cur:
            break
        cur = cur.parent
    cwd = Path.cwd().resolve()
    if (cwd / "memory").exists():
        return cwd
    raise SystemExit(
        "Could not resolve instance dir. Use --instance-dir, set JC_INSTANCE_DIR, "
        "or run from a directory containing memory/ or a .jc marker."
    )


# --- spawn -------------------------------------------------------------------


def cmd_spawn(args: argparse.Namespace) -> int:
    instance = resolve_instance_dir(args.instance_dir)

    # Validate adapter exists up-front — fail-fast is friendlier than a
    # detached child that silently marks itself failed.
    adapter = ADAPTERS_DIR / f"{args.brain}.sh"
    if not adapter.exists():
        raise SystemExit(f"adapter not found: {adapter}")
    if not os.access(adapter, os.X_OK):
        raise SystemExit(f"adapter not executable: {adapter}")

    # Sprint 3: if a name is given and --fresh is NOT set, look up the most
    # recent terminal-state run for that name and resume its session.
    resume_session_id: Optional[str] = None
    if args.name and not getattr(args, "fresh", False):
        conn_lookup = connect(instance)
        try:
            row = conn_lookup.execute(
                "SELECT session_id FROM workers "
                "WHERE name=? AND status IN ('done','failed','cancelled') "
                "AND session_id IS NOT NULL "
                "ORDER BY started_at DESC, id DESC LIMIT 1",
                (args.name,),
            ).fetchone()
            if row:
                resume_session_id = row["session_id"]
        finally:
            conn_lookup.close()

    # Read the prompt.
    if args.prompt == "-" or args.prompt is None:
        prompt_text = sys.stdin.read()
    else:
        prompt_file = Path(args.prompt).expanduser().resolve()
        # Security guard from spec §9: prompt must be inside instance dir.
        # Use is_relative_to (3.9+) — string prefix would accept sibling dirs
        # like /path/instance-evil/ when instance is /path/instance.
        try:
            inside = prompt_file.is_relative_to(instance)
        except AttributeError:  # pragma: no cover — Python < 3.9
            try:
                prompt_file.relative_to(instance)
                inside = True
            except ValueError:
                inside = False
        if not inside:
            raise SystemExit(
                f"--prompt must be inside instance dir ({instance}): {prompt_file}"
            )
        prompt_text = prompt_file.read_text(encoding="utf-8")

    if not prompt_text.strip():
        raise SystemExit("refusing to spawn with empty prompt")

    # Create the DB row first to get an id.
    conn = connect(instance)
    try:
        # Placeholder paths — we fill them after we know the id.
        tags_json = json.dumps(args.tag) if args.tag else None
        worker_id = create(
            conn,
            topic=args.topic,
            brain=args.brain,
            model=args.model,
            prompt_path="",
            log_path="",
            spawned_by=args.spawned_by,
            telegram_msg_id=args.telegram_msg_id,
            notify_chat_id=args.notify,
            timeout_seconds=args.timeout,
            name=args.name,
            tags=tags_json,
        )

        wdir = _worker_dir(instance, worker_id)
        wdir.mkdir(parents=True, exist_ok=True)
        prompt_path = wdir / "prompt"
        log_path = wdir / "log"
        prompt_path.write_text(prompt_text, encoding="utf-8")
        log_path.touch()

        meta = {
            "id": worker_id,
            "topic": args.topic,
            "brain": args.brain,
            "model": args.model,
            "spawned_by": args.spawned_by,
            "created_at": _now_iso(),
        }
        (wdir / "meta.json").write_text(
            json.dumps(meta, indent=2), encoding="utf-8"
        )

        conn.execute(
            "UPDATE workers SET prompt_path=?, log_path=? WHERE id=?",
            (str(prompt_path), str(log_path), worker_id),
        )
        conn.commit()
    finally:
        conn.close()

    # Propagate sandbox choice via env so the detached runner inherits it
    # and the adapter subprocess sees it too (os.environ.copy() is passed
    # through execvpe in _exec_runner). Each brain reads its own var — map
    # our single enum to both.
    os.environ["CODEX_SANDBOX"] = args.sandbox
    os.environ["GEMINI_YOLO"] = {
        "yolo": "true",
        "read-only": "plan",
        "workspace-write": "true",
    }[args.sandbox]

    # Sprint 3: pass the resume session id through to the adapter via env.
    # Each adapter reads WORKER_RESUME_SESSION and maps to its brain-specific flag.
    if resume_session_id:
        os.environ["WORKER_RESUME_SESSION"] = resume_session_id
    else:
        os.environ.pop("WORKER_RESUME_SESSION", None)

    # Detached double-fork so the runner survives this shell AND our process.
    # The child re-execs `jc-workers _run <id>` with its own session.
    pid = _double_fork_run(instance, worker_id)

    # Record the grandchild pid on the row immediately so `reconcile` can
    # detect crashes in the narrow queued→running window.
    conn = connect(instance)
    try:
        conn.execute("UPDATE workers SET pid=? WHERE id=?", (pid, worker_id))
        conn.commit()
    finally:
        conn.close()

    print(f"spawned worker #{worker_id} (pid {pid})")
    return 0


def _double_fork_run(instance: Path, worker_id: int) -> int:
    """Fork twice so the runner is fully detached (no controlling terminal,
    no parent process waiting). Returns the grandchild pid seen from the
    first fork.
    """
    # First fork.
    r, w = os.pipe()
    first = os.fork()
    if first == 0:
        # Child 1: become session leader, fork again, send pid up the pipe.
        os.close(r)
        os.setsid()
        second = os.fork()
        if second == 0:
            # Grandchild: close all stdio, exec _run.
            os.close(w)
            _exec_runner(instance, worker_id)
            os._exit(127)  # unreachable
        else:
            # Child 1 exits after reporting the grandchild pid.
            os.write(w, f"{second}".encode())
            os.close(w)
            os._exit(0)
    else:
        # Parent: wait for child 1 to exit, read grandchild pid.
        os.close(w)
        os.waitpid(first, 0)
        data = os.read(r, 32)
        os.close(r)
        return int(data.decode().strip()) if data else -1


def _exec_runner(instance: Path, worker_id: int) -> None:
    """In the detached grandchild: reopen stdio to /dev/null and exec
    `jc-workers _run <id>`. We do NOT return.
    """
    # Close inherited stdio.
    devnull_r = os.open(os.devnull, os.O_RDONLY)
    devnull_w = os.open(os.devnull, os.O_WRONLY)
    os.dup2(devnull_r, 0)
    os.dup2(devnull_w, 1)
    os.dup2(devnull_w, 2)

    # Locate ourselves on PATH (preferred) or fall back to the current file.
    exe = shutil.which("jc-workers") or sys.argv[0]
    os.execvpe(
        exe,
        [exe, "--instance-dir", str(instance), "_run", str(worker_id)],
        os.environ.copy(),
    )


# --- notifications -----------------------------------------------------------


def _duration_str(started: str, finished: str) -> str:
    """Format worker duration like '12s', '4m 32s', '1h 02m'."""
    try:
        t0 = datetime.strptime(started, "%Y-%m-%dT%H:%M:%SZ").replace(tzinfo=timezone.utc)
        t1 = datetime.strptime(finished, "%Y-%m-%dT%H:%M:%SZ").replace(tzinfo=timezone.utc)
    except Exception:  # noqa: BLE001
        return "?"
    secs = int((t1 - t0).total_seconds())
    if secs < 60:
        return f"{secs}s"
    if secs < 3600:
        return f"{secs // 60}m {secs % 60:02d}s"
    return f"{secs // 3600}h {(secs % 3600) // 60:02d}m"


def _format_notification(w: Worker) -> str:
    """Plain-text completion summary for send_telegram.sh (no markdown)."""
    duration = "?"
    if w.started_at and w.finished_at:
        duration = _duration_str(w.started_at, w.finished_at)

    brain_model = w.brain + (f" / {w.model}" if w.model else "")

    if w.status == "done":
        head = f"worker #{w.id} done ({duration})"
    elif w.status == "failed":
        head = f"worker #{w.id} FAILED (exit {w.exit_code if w.exit_code is not None else '?'})"
    elif w.status == "cancelled":
        head = f"worker #{w.id} cancelled"
    elif w.status == "need_input":
        head = f"worker #{w.id} needs input"
    else:
        head = f"worker #{w.id} {w.status}"

    lines = [
        head,
        f"topic: {w.topic}",
        f"brain: {brain_model}",
        "",
    ]

    if w.status == "need_input":
        lines.append(f"respawn with: jc workers spawn --topic '{w.topic}' --brain {w.brain} ...")
    elif w.status in ("failed", "cancelled"):
        if w.error:
            lines.append(f"error: {w.error}")
            lines.append("")
        lines.append(f"log: {w.log_path}")

    return "\n".join(lines)


def _send_notification(instance: Path, worker: Worker) -> None:
    """Invoke send_telegram.sh. Swallow errors — a failed notify shouldn't
    crash the runner and shouldn't flip the worker's status."""
    if not SEND_TELEGRAM.exists():
        return
    body = _format_notification(worker)
    env = os.environ.copy()
    env["JC_INSTANCE_DIR"] = str(instance)
    if worker.notify_chat_id:
        env["TELEGRAM_CHAT_ID_OVERRIDE"] = str(worker.notify_chat_id)
    try:
        subprocess.run(
            [str(SEND_TELEGRAM)],
            input=body,
            capture_output=True,
            text=True,
            env=env,
            timeout=25,
        )
    except Exception:  # noqa: BLE001
        # Intentionally silent — we log nothing because the runner's stderr
        # is already pointed at the worker log which is closed by now.
        pass


# --- session id capture ------------------------------------------------------


_UUID_RE = re.compile(
    r"[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}"
)


def _parse_iso(ts: str) -> Optional[float]:
    """Parse an ISO-ish timestamp to a UTC epoch seconds float, or None."""
    if not ts:
        return None
    try:
        return datetime.strptime(ts, "%Y-%m-%dT%H:%M:%SZ").replace(
            tzinfo=timezone.utc
        ).timestamp()
    except (TypeError, ValueError):
        pass
    try:
        return datetime.fromisoformat(ts.replace("Z", "+00:00")).timestamp()
    except (TypeError, ValueError):
        return None


def _capture_session_id(brain: str, instance: Path, started_at: str) -> Optional[str]:
    """Best-effort capture of the brain-native session id created during this run.

    Returns the session id string for `--resume`, or None on any failure.
    Never raises — a failed capture must not flip the worker to failed.
    """
    try:
        t0 = _parse_iso(started_at)
        if t0 is None:
            return None

        if brain == "claude":
            # Claude project slug: replace `/` and `_` with `-`, keep leading dash.
            # e.g. /home/lucamattei/rachel_zane → -home-lucamattei-rachel-zane
            slug = str(instance).replace("/", "-").replace("_", "-")
            proj_dir = Path.home() / ".claude" / "projects" / slug
            if not proj_dir.is_dir():
                return None
            best = None
            best_delta: Optional[float] = None
            for f in proj_dir.glob("*.jsonl"):
                try:
                    mtime = f.stat().st_mtime
                except OSError:
                    continue
                if mtime < t0:
                    continue
                delta = mtime - t0
                if best_delta is None or delta < best_delta:
                    best_delta = delta
                    best = f
            return best.stem if best else None

        if brain == "gemini":
            try:
                proc = subprocess.run(
                    ["gemini", "--list-sessions", "--format", "json"],
                    capture_output=True, text=True, timeout=5,
                )
            except (FileNotFoundError, subprocess.TimeoutExpired):
                return None
            if proc.returncode != 0 or not proc.stdout.strip():
                return None
            try:
                data = json.loads(proc.stdout)
            except json.JSONDecodeError:
                return None
            sessions = data if isinstance(data, list) else data.get("sessions", [])
            best = None
            best_delta = None
            for s in sessions:
                if not isinstance(s, dict):
                    continue
                ts = s.get("created_at") or s.get("started_at") or s.get("start")
                st = _parse_iso(ts) if isinstance(ts, str) else None
                if st is None:
                    continue
                delta = abs(st - t0)
                if best_delta is None or delta < best_delta:
                    best_delta = delta
                    best = s
            if not best:
                return None
            sid = best.get("id") or best.get("session_id") or best.get("index")
            return str(sid) if sid is not None else None

        if brain == "codex":
            codex_dir = Path.home() / ".codex"
            if not codex_dir.is_dir():
                return None
            sessions_dir = codex_dir / "sessions"
            search_root = sessions_dir if sessions_dir.is_dir() else codex_dir
            best = None
            best_delta = None
            for f in search_root.rglob("*.jsonl"):
                try:
                    mtime = f.stat().st_mtime
                except OSError:
                    continue
                if mtime < t0:
                    continue
                delta = mtime - t0
                if best_delta is None or delta < best_delta:
                    best_delta = delta
                    best = f
            if not best:
                return None
            m = _UUID_RE.search(best.stem)
            return m.group(0) if m else best.stem

        if brain == "opencode":
            try:
                proc = subprocess.run(
                    ["opencode", "session", "list", "--format", "json"],
                    capture_output=True, text=True, timeout=5,
                )
            except (FileNotFoundError, subprocess.TimeoutExpired):
                return None
            if proc.returncode != 0 or not proc.stdout.strip():
                return None
            try:
                data = json.loads(proc.stdout)
            except json.JSONDecodeError:
                return None
            sessions = data if isinstance(data, list) else data.get("sessions", [])
            best = None
            best_delta = None
            for s in sessions:
                if not isinstance(s, dict):
                    continue
                ts = s.get("created_at") or s.get("started_at") or s.get("start")
                st = _parse_iso(ts) if isinstance(ts, str) else None
                if st is None:
                    continue
                delta = abs(st - t0)
                if best_delta is None or delta < best_delta:
                    best_delta = delta
                    best = s
            if not best:
                return None
            sid = best.get("id") or best.get("session_id")
            return str(sid) if sid is not None else None

        return None
    except Exception as e:  # noqa: BLE001
        print(
            f"warning: session id capture failed for {brain}: {e}",
            file=sys.stderr,
        )
        return None


# --- _run (detached runner) --------------------------------------------------


def cmd_run(args: argparse.Namespace) -> int:
    """The body that runs in the detached grandchild.

    Reads prompt → pipes to adapter → captures stdout to result + log →
    updates DB on exit. Failures are caught and recorded, not raised.
    """
    instance = resolve_instance_dir(args.instance_dir)
    worker_id = int(args.worker_id)

    conn = connect(instance)
    try:
        worker = get(conn, worker_id)
        if worker is None:
            sys.exit(f"worker {worker_id} not found")

        prompt_path = Path(worker.prompt_path)
        log_path = Path(worker.log_path)
        result_path = _worker_dir(instance, worker_id) / "result"

        adapter = ADAPTERS_DIR / f"{worker.brain}.sh"
        if not adapter.exists():
            mark_terminal(
                conn,
                worker_id,
                status="failed",
                exit_code=127,
                error=f"adapter missing: {adapter}",
            )
            w_failed = get(conn, worker_id)
            if w_failed:
                _send_notification(instance, w_failed)
            return 127

        mark_running(conn, worker_id, os.getpid())
    finally:
        conn.close()

    # Run the adapter. Stdin = prompt. Stdout → result (clean). Stderr → log.
    with prompt_path.open("rb") as stdin_f, \
         result_path.open("wb") as stdout_f, \
         log_path.open("ab") as log_f:

        log_f.write(
            f"[{_now_iso()}] spawn worker={worker_id} brain={worker.brain} "
            f"model={worker.model or '-'} adapter={adapter}\n".encode()
        )
        log_f.flush()

        timed_out = False
        try:
            # start_new_session=True puts the adapter in its own session/pgid
            # so killpg on timeout only hits the adapter tree, not the runner.
            proc = subprocess.Popen(
                [str(adapter), worker.model or ""],
                stdin=stdin_f,
                stdout=stdout_f,
                stderr=log_f,
                cwd=str(instance),
                start_new_session=True,
            )
            try:
                exit_code = proc.wait(timeout=worker.timeout_seconds)
            except subprocess.TimeoutExpired:
                timed_out = True
                _killpg(proc.pid, signal.SIGTERM)
                try:
                    exit_code = proc.wait(timeout=5)
                except subprocess.TimeoutExpired:
                    _killpg(proc.pid, signal.SIGKILL)
                    exit_code = proc.wait()
        except Exception as e:  # noqa: BLE001
            conn = connect(instance)
            try:
                mark_terminal(
                    conn,
                    worker_id,
                    status="failed",
                    error=f"spawn exception: {e}",
                )
                w_failed = get(conn, worker_id)
            finally:
                conn.close()
            if w_failed:
                _send_notification(instance, w_failed)
            return 1

    # Read last stderr line for error reporting on failure.
    last_err = ""
    if timed_out:
        last_err = f"timeout after {worker.timeout_seconds}s"
    elif exit_code != 0:
        try:
            log_tail = log_path.read_text(encoding="utf-8", errors="replace")
            # Use last non-empty line.
            for line in reversed(log_tail.splitlines()):
                if line.strip():
                    last_err = line.strip()[:500]
                    break
        except Exception:  # noqa: BLE001
            pass

    # Detect the NEED_INPUT: sentinel — worker finished cleanly but is
    # asking the user a question it can't resolve. Surfaces as a distinct
    # status so callers can route the prompt back after clarification.
    need_input = False
    if exit_code == 0 and not timed_out:
        try:
            head = result_path.open("rb").read(64).decode("utf-8", errors="replace")
            if head.lstrip().startswith("NEED_INPUT:"):
                need_input = True
        except Exception:  # noqa: BLE001
            pass

    if timed_out:
        status = "failed"
    elif need_input:
        status = "need_input"
    elif exit_code == 0:
        status = "done"
    else:
        status = "failed"
    conn = connect(instance)
    try:
        mark_terminal(
            conn,
            worker_id,
            status=status,
            exit_code=exit_code,
            result_path=str(result_path),
            error=last_err or None,
        )
        worker = get(conn, worker_id)
    finally:
        conn.close()

    # Named workers: try to capture brain-native session id so the next
    # spawn with the same name can --resume. Best-effort, never fatal.
    if worker is not None and worker.name:
        sid = _capture_session_id(
            worker.brain, instance, worker.started_at or _now_iso()
        )
        if sid:
            conn2 = connect(instance)
            try:
                conn2.execute(
                    "UPDATE workers SET session_id=? WHERE id=?",
                    (sid, worker_id),
                )
                conn2.commit()
            finally:
                conn2.close()
            worker.session_id = sid

    if worker is not None:
        _send_notification(instance, worker)
    return 0


# --- list --------------------------------------------------------------------


def cmd_list(args: argparse.Namespace) -> int:
    instance = resolve_instance_dir(args.instance_dir)
    conn = connect(instance)
    try:
        rows = list_workers(
            conn, status=args.status, name=args.name, limit=args.limit
        )
    finally:
        conn.close()

    # Tag filter applied post-fetch via JSON parse.
    if args.tag:
        filtered = []
        for w in rows:
            try:
                tag_list = json.loads(w.tags or "[]")
            except json.JSONDecodeError:
                tag_list = []
            if args.tag in tag_list:
                filtered.append(w)
        rows = filtered

    if not rows:
        print("(no workers)")
        return 0

    def _trunc(s: str, width: int) -> str:
        return s if len(s) <= width else s[: width - 1] + "…"

    print(
        f"{'ID':>4}  {'STATUS':<10}  {'BRAIN':<10}  {'MODEL':<22}  "
        f"{'NAME':<15}  {'TAGS':<20}  {'STARTED':<20}  TOPIC"
    )
    print("-" * 130)
    for w in rows:
        started = (w.started_at or "")[:19]
        name = _trunc(w.name or "-", 15)
        try:
            tag_list = json.loads(w.tags or "[]")
        except json.JSONDecodeError:
            tag_list = []
        tags_str = _trunc(",".join(tag_list) if tag_list else "-", 20)
        print(
            f"{w.id:>4}  {w.status:<10}  {w.brain:<10}  {(w.model or '-'):<22}  "
            f"{name:<15}  {tags_str:<20}  {started:<20}  {w.topic}"
        )
    return 0


# --- show --------------------------------------------------------------------


def cmd_show(args: argparse.Namespace) -> int:
    instance = resolve_instance_dir(args.instance_dir)
    if not args.worker_id and not args.name:
        raise SystemExit("show requires either <id> or --name <slug>")

    total_runs: Optional[int] = None
    conn = connect(instance)
    try:
        if args.name:
            terminal = ("done", "failed", "cancelled", "need_input")
            placeholders = ",".join("?" * len(terminal))
            row = conn.execute(
                f"SELECT * FROM workers WHERE name=? AND status IN ({placeholders}) "
                "ORDER BY started_at DESC, id DESC LIMIT 1",
                (args.name, *terminal),
            ).fetchone()
            if not row:
                raise SystemExit(
                    f"no terminal-state worker found with name '{args.name}'"
                )
            w = Worker.from_row(row)
            total_runs = conn.execute(
                "SELECT COUNT(*) FROM workers WHERE name=?", (args.name,)
            ).fetchone()[0]
        else:
            w = get(conn, int(args.worker_id))
    finally:
        conn.close()
    if not w:
        raise SystemExit(f"worker {args.worker_id} not found")

    header = f"worker #{w.id}  [{w.status}]"
    if total_runs is not None:
        header += f"  ({total_runs} total runs for '{args.name}')"
    print(header)
    print(f"  topic       {w.topic}")
    print(f"  brain       {w.brain}")
    print(f"  model       {w.model or '-'}")
    print(f"  pid         {w.pid or '-'}")
    print(f"  exit_code   {w.exit_code if w.exit_code is not None else '-'}")
    print(f"  started_at  {w.started_at}")
    print(f"  finished_at {w.finished_at or '-'}")
    print(f"  prompt      {w.prompt_path}")
    print(f"  log         {w.log_path}")
    print(f"  result      {w.result_path or '-'}")
    print(f"  notify      {w.notify_chat_id or '(default)'}")
    if w.error:
        print(f"  error       {w.error}")

    if w.result_path and Path(w.result_path).exists():
        body = Path(w.result_path).read_text(encoding="utf-8", errors="replace")
        print("\n--- result ---")
        print(body[:2000])
        if len(body) > 2000:
            print(f"... ({len(body) - 2000} more chars)")
    return 0


# --- history -----------------------------------------------------------------


def cmd_history(args: argparse.Namespace) -> int:
    instance = resolve_instance_dir(args.instance_dir)
    conn = connect(instance)
    try:
        rows = conn.execute(
            "SELECT * FROM workers WHERE name=? ORDER BY started_at DESC",
            (args.name,),
        ).fetchall()
    finally:
        conn.close()

    workers = [Worker.from_row(r) for r in rows]
    if not workers:
        print(f"(no workers with name '{args.name}')")
        return 0

    def _trunc(s: str, width: int) -> str:
        return s if len(s) <= width else s[: width - 1] + "…"

    print(
        f"{'ID':>6}  {'STATUS':<10}  {'TOPIC':<20}  {'BRAIN':<8}  "
        f"{'STARTED':<19}  {'SESSION':<8}"
    )
    print("-" * 85)
    for w in workers:
        topic = _trunc(w.topic, 20)
        started = (w.started_at or "")[:19]
        sess = (w.session_id or "-")[:8]
        print(
            f"{w.id:>6}  {w.status:<10}  {topic:<20}  {w.brain:<8}  "
            f"{started:<19}  {sess:<8}"
        )
    return 0


# --- process helpers ---------------------------------------------------------


def _pid_alive(pid: int) -> bool:
    """True if the pid exists. Using signal 0 pings the process without
    affecting it."""
    try:
        os.kill(pid, 0)
    except ProcessLookupError:
        return False
    except PermissionError:
        return True
    return True


def _killpg(pid: int, sig: int) -> None:
    """killpg by looking up the pid's process group. Swallow lookup errors
    (process already dead)."""
    try:
        pgid = os.getpgid(pid)
        os.killpg(pgid, sig)
    except ProcessLookupError:
        pass


# --- cancel ------------------------------------------------------------------


def cmd_cancel(args: argparse.Namespace) -> int:
    instance = resolve_instance_dir(args.instance_dir)
    worker_id = int(args.worker_id)

    conn = connect(instance)
    try:
        w = get(conn, worker_id)
    finally:
        conn.close()
    if not w:
        raise SystemExit(f"worker {worker_id} not found")
    if w.status not in ("running", "queued"):
        raise SystemExit(f"worker {worker_id} is {w.status}, not running")

    if w.pid is not None and _pid_alive(w.pid):
        _killpg(w.pid, signal.SIGTERM)
        # Grace period: up to 5 seconds.
        for _ in range(10):
            if not _pid_alive(w.pid):
                break
            time.sleep(0.5)
        if _pid_alive(w.pid):
            _killpg(w.pid, signal.SIGKILL)

    conn = connect(instance)
    try:
        mark_terminal(
            conn,
            worker_id,
            status="cancelled",
            error="cancelled by user",
        )
        w_fresh = get(conn, worker_id)
    finally:
        conn.close()

    if w_fresh:
        _send_notification(instance, w_fresh)

    print(f"worker #{worker_id} cancelled")
    return 0


# --- gc ----------------------------------------------------------------------


def cmd_gc(args: argparse.Namespace) -> int:
    instance = resolve_instance_dir(args.instance_dir)
    cutoff_dt = datetime.now(timezone.utc) - timedelta(days=args.days)
    cutoff = cutoff_dt.strftime("%Y-%m-%dT%H:%M:%SZ")

    conn = connect(instance)
    try:
        rows = conn.execute(
            """
            SELECT id FROM workers
            WHERE status IN ('done','failed','cancelled')
              AND (finished_at IS NOT NULL AND finished_at < ?)
            """,
            (cutoff,),
        ).fetchall()
        ids = [r["id"] for r in rows]

        for wid in ids:
            if args.prune_files:
                wdir = _worker_dir(instance, wid)
                if wdir.exists():
                    shutil.rmtree(wdir, ignore_errors=True)
            conn.execute("DELETE FROM workers WHERE id = ?", (wid,))
        conn.commit()
    finally:
        conn.close()

    print(
        f"removed {len(ids)} workers older than {args.days}d"
        + (" (+ files)" if args.prune_files else "")
    )
    return 0


# --- reconcile ---------------------------------------------------------------


def cmd_reconcile(args: argparse.Namespace) -> int:
    """Scan for workers in non-terminal states whose pid is no longer alive,
    mark them failed. Intended to run at main-session startup."""
    instance = resolve_instance_dir(args.instance_dir)

    # Skip rows younger than this — spawn writes the row 'queued' with pid=NULL
    # and only sets pid after double-fork returns, so a reconcile during that
    # window would falsely flag a healthy new worker as an orphan.
    fresh_cutoff = datetime.now(timezone.utc) - timedelta(seconds=10)

    conn = connect(instance)
    try:
        rows = conn.execute(
            "SELECT id, pid, started_at FROM workers "
            "WHERE status IN ('queued','running','need_input')"
        ).fetchall()
        orphans = []
        skipped_fresh = 0
        for r in rows:
            try:
                started = datetime.strptime(
                    r["started_at"], "%Y-%m-%dT%H:%M:%SZ"
                ).replace(tzinfo=timezone.utc)
            except (TypeError, ValueError):
                started = None
            if started is not None and started > fresh_cutoff:
                skipped_fresh += 1
                continue
            pid = r["pid"]
            if pid is None or not _pid_alive(pid):
                orphans.append(r["id"])
        for wid in orphans:
            mark_terminal(
                conn,
                wid,
                status="failed",
                error="orphan: pid not alive at reconcile",
            )
    finally:
        conn.close()

    msg = f"reconciled {len(orphans)} orphan(s) of {len(rows)} live row(s)"
    if skipped_fresh:
        msg += f" (skipped {skipped_fresh} fresh <10s)"
    print(msg)
    return 0


# --- tail --------------------------------------------------------------------


def cmd_tail(args: argparse.Namespace) -> int:
    instance = resolve_instance_dir(args.instance_dir)
    conn = connect(instance)
    try:
        w = get(conn, int(args.worker_id))
    finally:
        conn.close()
    if not w:
        raise SystemExit(f"worker {args.worker_id} not found")

    os.execvp("tail", ["tail", "-n", "200", "-f", w.log_path])
    return 0  # unreachable


# --- argparse ----------------------------------------------------------------


def build_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(prog="jc-workers")
    p.add_argument("--instance-dir", help="override instance dir")
    subs = p.add_subparsers(dest="cmd", required=True)

    sp = subs.add_parser("spawn", help="spawn a background worker")
    sp.add_argument("--topic", required=True, help="short human label")
    sp.add_argument("--brain", required=True, help="adapter name (claude|codex|gemini|opencode)")
    sp.add_argument("--model", default=None, help="optional model override")
    sp.add_argument("--notify", default=None, help="telegram chat_id for completion")
    sp.add_argument("--timeout", type=int, default=None, help="soft timeout in seconds")
    sp.add_argument("--spawned-by", default="user", help="free-form origin label")
    sp.add_argument("--telegram-msg-id", default=None, help="inbound msg that triggered the spawn")
    sp.add_argument("--prompt", default="-", help="prompt file path, or '-' for stdin")
    sp.add_argument("--name", default=None,
                    help="persistent identity slug; resumes prior session if session_id was captured")
    sp.add_argument("--tag", action="append", default=None,
                    help="tag for filtering (repeatable)")
    sp.add_argument("--fresh", action="store_true",
                    help="ignore prior session when resuming a named worker")
    sandbox = sp.add_mutually_exclusive_group()
    sandbox.add_argument("--read-only", dest="sandbox", action="store_const", const="read-only",
                         help="codex + gemini: read files but don't edit them")
    sandbox.add_argument("--yolo", dest="sandbox", action="store_const", const="yolo",
                         help="codex + gemini: bypass sandbox + approvals (DANGEROUS)")
    sp.set_defaults(sandbox="workspace-write")

    rp = subs.add_parser("_run", help=argparse.SUPPRESS)
    rp.add_argument("worker_id")

    lp = subs.add_parser("list", help="list workers")
    lp.add_argument("--status", default=None,
                    choices=["queued", "running", "done", "failed", "cancelled",
                             "need_input", "all"],
                    help="filter by status")
    lp.add_argument("--name", default=None, help="filter by name")
    lp.add_argument("--tag", default=None, help="filter by tag (membership in tags JSON array)")
    lp.add_argument("--limit", type=int, default=20)

    shp = subs.add_parser("show", help="show one worker's details")
    shp.add_argument("worker_id", nargs="?", default=None)
    shp.add_argument("--name", default=None,
                     help="show latest terminal-state run for this name")

    tp = subs.add_parser("tail", help="tail -f a worker's log")
    tp.add_argument("worker_id")

    cp = subs.add_parser("cancel", help="cancel a running worker")
    cp.add_argument("worker_id")

    gp = subs.add_parser("gc", help="delete old completed workers")
    gp.add_argument("--days", type=int, default=7,
                    help="remove workers finished before N days ago (default: 7)")
    gp.add_argument("--prune-files", action="store_true",
                    help="also remove state/workers/<id>/ directories")

    rp = subs.add_parser("reconcile",
                         help="mark stale 'running' rows as failed if pid is dead")

    hp = subs.add_parser("history",
                         help="all runs for a named worker, newest first")
    hp.add_argument("--name", required=True, help="named worker slug")

    return p


HANDLERS = {
    "spawn": cmd_spawn,
    "_run": cmd_run,
    "list": cmd_list,
    "show": cmd_show,
    "tail": cmd_tail,
    "cancel": cmd_cancel,
    "gc": cmd_gc,
    "reconcile": cmd_reconcile,
    "history": cmd_history,
}


def main() -> int:
    args = build_parser().parse_args()
    return HANDLERS[args.cmd](args)


if __name__ == "__main__":
    sys.exit(main())
