#!/usr/bin/env bash
# jc-setup - guided first-run configurator for a JuliusCaesar instance.
#
# Usage:
#   jc-setup [<path>] [--defaults] [--start] [--install-watchdog]
#
# This is the friendly path. It uses jc-init for the low-level scaffold, then
# writes concrete instance context so the first live Claude session knows what
# this assistant is supposed to do.

set -euo pipefail

FRAMEWORK_ROOT="$(cd "$(dirname "$(readlink -f "$0" 2>/dev/null || echo "$0")")/.." && pwd)"
JC_INIT="$FRAMEWORK_ROOT/bin/jc-init"
JC_MEMORY="$FRAMEWORK_ROOT/bin/jc-memory"
JC_DOCTOR="$FRAMEWORK_ROOT/bin/jc-doctor"
JC_WATCHDOG="$FRAMEWORK_ROOT/bin/jc-watchdog"
JC_GATEWAY="$FRAMEWORK_ROOT/bin/jc-gateway"

USE_DEFAULTS=0
START_LIVE=""
INSTALL_WATCHDOG=""
TARGET=""
WRITE_CONFIG=yes

usage() {
    cat <<'EOF'
jc-setup - guided first-run configurator

Usage:
  jc setup [<path>] [--defaults] [--start] [--no-start] [--install-watchdog] [--no-watchdog]

Options:
  --defaults            Use safe defaults and do not prompt.
  --start               Start the gateway daemon after setup.
  --no-start            Do not start a live session.
  --install-watchdog    Install watchdog cron entries after setup.
  --no-watchdog         Do not install watchdog cron entries.
EOF
}

while (( $# )); do
    case "$1" in
        -h|--help|help) usage; exit 0 ;;
        --defaults) USE_DEFAULTS=1; shift ;;
        --start) START_LIVE=yes; shift ;;
        --no-start) START_LIVE=no; shift ;;
        --install-watchdog) INSTALL_WATCHDOG=yes; shift ;;
        --no-watchdog) INSTALL_WATCHDOG=no; shift ;;
        --*) echo "Unknown option: $1" >&2; usage >&2; exit 2 ;;
        *)
            if [[ -n "$TARGET" ]]; then
                echo "Unexpected extra argument: $1" >&2
                usage >&2
                exit 2
            fi
            TARGET="$1"
            shift
            ;;
    esac
done

TARGET="${TARGET:-$(pwd)}"
mkdir -p "$TARGET"
TARGET="$(cd "$TARGET" && pwd)"

prompt() {
    local label="$1"
    local default="${2:-}"
    local value
    if [[ "$USE_DEFAULTS" == 1 ]]; then
        printf '%s\n' "$default"
        return 0
    fi
    if [[ -n "$default" ]]; then
        printf '%s [%s]: ' "$label" "$default" >&2
    else
        printf '%s: ' "$label" >&2
    fi
    IFS= read -r value || value=""
    if [[ -z "$value" ]]; then
        printf '%s\n' "$default"
    else
        printf '%s\n' "$value"
    fi
}

secret_prompt() {
    local label="$1"
    local default="${2:-}"
    local value
    if [[ "$USE_DEFAULTS" == 1 ]]; then
        printf '%s\n' "$default"
        return 0
    fi
    if [[ -n "$default" ]]; then
        printf '%s [keep existing]: ' "$label" >&2
    else
        printf '%s: ' "$label" >&2
    fi
    IFS= read -rs value || value=""
    printf '\n' >&2
    if [[ -z "$value" ]]; then
        printf '%s\n' "$default"
    else
        printf '%s\n' "$value"
    fi
}

yesno() {
    local label="$1"
    local default="${2:-no}"
    local value
    if [[ "$USE_DEFAULTS" == 1 ]]; then
        printf '%s\n' "$default"
        return 0
    fi
    while :; do
        printf '%s [%s]: ' "$label" "$default" >&2
        IFS= read -r value || value=""
        value="${value:-$default}"
        case "$value" in
            y|Y|yes|YES|Yes) printf 'yes\n'; return 0 ;;
            n|N|no|NO|No) printf 'no\n'; return 0 ;;
            *) echo "Please answer yes or no." >&2 ;;
        esac
    done
}

trim_value() {
    local value="$1"
    value="${value#"${value%%[![:space:]]*}"}"
    value="${value%"${value##*[![:space:]]}"}"
    if [[ "$value" == \'* && "$value" == *\' ]]; then
        value="${value:1:${#value}-2}"
    elif [[ "$value" == \"* && "$value" == *\" ]]; then
        value="${value:1:${#value}-2}"
    fi
    printf '%s\n' "$value"
}

env_value() {
    local key="$1"
    local file="$TARGET/.env"
    [[ -f "$file" ]] || return 0
    local raw
    raw=$(awk -F= -v key="$key" '$1 == key { print substr($0, index($0, "=") + 1); exit }' "$file")
    trim_value "$raw"
}

shell_quote() {
    local value="$1"
    printf "'"
    printf '%s' "$value" | sed "s/'/'\\\\''/g"
    printf "'"
}

write_env() {
    local dashscope="$1"
    local telegram_token="$2"
    local telegram_chat="$3"
    local slack_app_token="$4"
    local slack_bot_token="$5"
    local tmp old_umask
    old_umask=$(umask)
    umask 077
    tmp=$(mktemp "$TARGET/.env.tmp.XXXXXX")
    {
        printf '%s\n' "# JuliusCaesar instance secrets. Do not commit."
        printf 'DASHSCOPE_API_KEY=%s\n' "$(shell_quote "$dashscope")"
        printf 'TELEGRAM_BOT_TOKEN=%s\n' "$(shell_quote "$telegram_token")"
        printf 'TELEGRAM_CHAT_ID=%s\n' "$(shell_quote "$telegram_chat")"
        printf 'SLACK_APP_TOKEN=%s\n' "$(shell_quote "$slack_app_token")"
        printf 'SLACK_BOT_TOKEN=%s\n' "$(shell_quote "$slack_bot_token")"
    } > "$tmp"
    umask "$old_umask"
    mv "$tmp" "$TARGET/.env"
    chmod 600 "$TARGET/.env"
}

write_identity() {
    local path="$1"
    local today="$2"
    local assistant_name="$3"
    local mission="$4"
    local style="$5"
    {
        cat <<EOF
---
slug: IDENTITY
title: Identity
layer: L1
type: identity
state: reviewed
created: $today
updated: $today
last_verified: "$today"
tags: [identity]
links: [USER, RULES]
---

# Who this assistant is

EOF
        printf '%s\n\n' "$assistant_name is a JuliusCaesar assistant running inside this instance. The assistant is persistent, practical, and expected to operate like a daemon-backed personal AI rather than a blank chat session."
        cat <<'EOF'
## Mission

EOF
        printf '%s\n\n' "$mission"
        cat <<'EOF'
## Operating posture

- Use the local instance as source of truth for identity, memory, heartbeat tasks, voice, watchdog, and credentials.
- Use the jc CLI for memory search/read/rebuild, heartbeat tasks, workers, voice, watchdog status, and diagnostics.
- Before answering from long-term context, search memory when needed instead of guessing.
- Keep framework code and instance data separate.
- Never expose secrets from .env.

## Voice and style

EOF
        printf '%s\n' "$style"
    } > "$path"
}

write_user_profile() {
    local path="$1"
    local today="$2"
    local user_name="$3"
    local timezone="$4"
    local style="$5"
    {
        cat <<EOF
---
slug: USER
title: User profile
layer: L1
type: user
state: reviewed
created: $today
updated: $today
last_verified: "$today"
tags: [user, profile]
links: [IDENTITY, RULES]
---

# Who the assistant is helping

## Identity

EOF
        printf -- '- Name: %s\n' "$user_name"
        printf -- '- Timezone: %s\n\n' "$timezone"
        cat <<'EOF'
## Communication preferences

EOF
        printf -- '- Preferred style: %s\n' "$style"
        cat <<'EOF'
- Ask concise clarifying questions only when needed to avoid a bad action.

## Standing context

- This instance was configured with jc setup.
- Use jc doctor to inspect environment and runtime health.
- Use jc memory rebuild after memory edits.
EOF
    } > "$path"
}

write_rules() {
    local path="$1"
    local today="$2"
    local external_policy="$3"
    {
        cat <<EOF
---
slug: RULES
title: Standing Rules & Feedback
layer: L1
type: rules
state: reviewed
created: $today
updated: $today
last_verified: "$today"
tags: [rules, feedback]
links: [USER, IDENTITY]
---

# Standing rules

## Instance awareness

Why: Claude starts fresh, but this instance carries durable context.
How to apply: Read this L1 memory at session start. Use jc memory search and jc memory read for L2 context.

## External actions

Why: The assistant can affect real systems through CLI tools, Telegram, cron, and files.
How to apply:
EOF
        printf ' %s\n\n' "$external_policy"
        cat <<'EOF'
## Work routing

Why: The live Claude session should stay responsive.
How to apply: Do quick answers inline. For longer dev work, research, scaffolding, or test-heavy tasks, use jc workers spawn when available.
EOF
    } > "$path"
}

write_hot() {
    local path="$1"
    local today="$2"
    cat > "$path" <<EOF
---
slug: HOT
title: Hot Cache (last 7 days)
layer: L1
type: hot
state: reviewed
created: $today
updated: $today
last_verified: "$today"
tags: [hot, recent, rolling]
links: [IDENTITY, USER, RULES]
---

# Hot cache - rolling 7-day context

## Today

- $today: Instance configured with jc setup.

## Open questions

-
EOF
}

write_l1() {
    local assistant_name="$1"
    local user_name="$2"
    local timezone="$3"
    local mission="$4"
    local style="$5"
    local external_policy="$6"
    local today
    today="$(date +%F)"

    write_identity "$TARGET/memory/L1/IDENTITY.md" "$today" "$assistant_name" "$mission" "$style"
    write_user_profile "$TARGET/memory/L1/USER.md" "$today" "$user_name" "$timezone" "$style"
    write_rules "$TARGET/memory/L1/RULES.md" "$today" "$external_policy"
    write_hot "$TARGET/memory/L1/HOT.md" "$today"
}

write_watchdog_conf() {
    local assistant_name="$1"
    local screen_name
    screen_name="$(printf '%s' "$assistant_name" | tr '[:upper:]' '[:lower:]' | tr -cs 'a-z0-9_' '-' | sed 's/^-//; s/-$//')"
    screen_name="${screen_name:-jc-assistant}"
    cat > "$TARGET/ops/watchdog.conf" <<EOF
# Watchdog configuration for this JuliusCaesar instance.

# Runtime mode: gateway is the default production runtime. Use "legacy-claude"
# only when intentionally supervising a live Claude Telegram plugin session.
RUNTIME_MODE=gateway

# Legacy Claude fallback settings. Fill SESSION_ID only if using legacy-claude.
SESSION_ID=

# GNU screen session name.
SCREEN_NAME=$screen_name

# Extra args passed when watchdog starts Claude.
CLAUDE_ARGS_EXTRA="--dangerously-skip-permissions --chrome --channels plugin:telegram@claude-plugins-official"
EOF
}

write_gateway_config() {
    local default_brain="$1"
    local telegram_enabled="$2"
    local telegram_chat="$3"
    local slack_enabled="$4"
    PYTHONPATH="$FRAMEWORK_ROOT/lib" python3 - "$TARGET" "$default_brain" "$telegram_enabled" "$telegram_chat" "$slack_enabled" <<'PY'
from pathlib import Path
import sys
from gateway.config import render_default_config

target = Path(sys.argv[1])
target.joinpath("ops").mkdir(parents=True, exist_ok=True)
target.joinpath("ops", "gateway.yaml").write_text(
    render_default_config(
        default_brain=sys.argv[2],
        telegram_enabled=sys.argv[3] == "yes",
        telegram_chat_id=sys.argv[4],
        slack_enabled=sys.argv[5] == "yes",
    ),
    encoding="utf-8",
)
PY
}

start_gateway() {
    local assistant_name="$1"
    "$JC_GATEWAY" --instance-dir "$TARGET" start
    echo "Started gateway runtime for $assistant_name."
}

echo "==> JuliusCaesar guided setup"
echo "Target: $TARGET"

if [[ ! -f "$TARGET/.jc" ]]; then
    if ! "$JC_INIT" "$TARGET"; then
        echo "jc setup: failed to initialize instance at $TARGET" >&2
        exit 1
    fi
else
    echo "==> Existing JC instance detected; configuring in place."
    if [[ "$USE_DEFAULTS" != 1 ]]; then
        WRITE_CONFIG="$(yesno "Rewrite .env, L1 memory, and watchdog config from setup answers?" "no")"
    fi
fi

default_assistant="$(basename "$TARGET")"
default_user="${USER:-user}"
default_timezone="${TZ:-$(date +%Z 2>/dev/null || echo UTC)}"

assistant_name="$default_assistant"
if [[ "$WRITE_CONFIG" == "yes" ]]; then
    assistant_name="$(prompt "Assistant name" "$default_assistant")"
    user_name="$(prompt "Your name" "$default_user")"
    timezone="$(prompt "Timezone" "$default_timezone")"
    mission="$(prompt "What should this assistant help with?" "Personal assistant for memory, scheduled tasks, development work, and Telegram-based operations.")"
    style="$(prompt "Communication style" "Concise, practical, warm, and explicit about uncertainty.")"
    external_policy="$(prompt "External-action policy" "Ask before irreversible external actions; proceed autonomously for local reads, diagnostics, and safe scaffolding.")"

    existing_dashscope="$(env_value DASHSCOPE_API_KEY)"
    existing_telegram_token="$(env_value TELEGRAM_BOT_TOKEN)"
    existing_telegram_chat="$(env_value TELEGRAM_CHAT_ID)"
    existing_slack_app_token="$(env_value SLACK_APP_TOKEN)"
    existing_slack_bot_token="$(env_value SLACK_BOT_TOKEN)"

    dashscope="$(secret_prompt "DashScope API key (optional)" "$existing_dashscope")"
    telegram_token="$(secret_prompt "Telegram bot token (optional)" "$existing_telegram_token")"
    telegram_chat="$(prompt "Telegram chat id (optional)" "$existing_telegram_chat")"
    slack_app_token="$(secret_prompt "Slack app-level token xapp-* for Socket Mode (optional)" "$existing_slack_app_token")"
    slack_bot_token="$(secret_prompt "Slack bot token xoxb-* (optional)" "$existing_slack_bot_token")"
    default_brain="$(prompt "Default gateway brain (claude|codex|opencode|gemini)" "claude")"
    case "$default_brain" in
        claude|codex|opencode|gemini) ;;
        *) echo "Unknown brain '$default_brain'; using claude." >&2; default_brain=claude ;;
    esac

    write_env "$dashscope" "$telegram_token" "$telegram_chat" "$slack_app_token" "$slack_bot_token"
    write_l1 "$assistant_name" "$user_name" "$timezone" "$mission" "$style" "$external_policy"
    write_watchdog_conf "$assistant_name"
    write_gateway_config "$default_brain" "$([[ -n "$telegram_token" ]] && echo yes || echo no)" "$telegram_chat" "$([[ -n "$slack_app_token" && -n "$slack_bot_token" ]] && echo yes || echo no)"
else
    echo "==> Keeping existing .env, L1 memory, watchdog config, and gateway config."
fi

echo "==> Rebuilding memory index"
"$JC_MEMORY" --instance-dir "$TARGET" rebuild >/dev/null

if [[ -z "$START_LIVE" ]]; then
    START_LIVE="$(yesno "Start gateway daemon now?" "no")"
fi
if [[ "$START_LIVE" == "yes" ]]; then
    start_gateway "$assistant_name" || true
fi

if [[ -z "$INSTALL_WATCHDOG" ]]; then
    INSTALL_WATCHDOG="$(yesno "Install watchdog cron entries?" "no")"
fi
if [[ "$INSTALL_WATCHDOG" == "yes" ]]; then
    "$JC_WATCHDOG" --instance-dir "$TARGET" install
fi

echo "==> Running doctor"
"$JC_DOCTOR" --instance-dir="$TARGET" || true

cat <<EOF

Setup complete.

Instance: $TARGET

Next useful commands:
  cd "$TARGET"
  jc doctor --fix
  jc gateway status
  jc heartbeat run hello --dry-run
EOF
