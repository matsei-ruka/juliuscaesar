#!/usr/bin/env python3
"""Guided first-run setup for a JuliusCaesar instance."""

from __future__ import annotations

import argparse
import json
import os
import shutil
import subprocess
import sys
import time
import urllib.parse
import urllib.request
from dataclasses import dataclass
from datetime import datetime, timezone
from pathlib import Path
from typing import Any

HERE = Path(__file__).resolve().parent
ROOT = HERE.parent
LIB = ROOT / "lib"
if str(LIB) not in sys.path:
    sys.path.insert(0, str(LIB))

from gateway.config import render_default_config  # type: ignore  # noqa: E402
from gateway.config_writer import atomic_write_text  # type: ignore  # noqa: E402


SUPPORTED_BRAINS = ("claude", "codex", "gemini", "opencode", "aider")
ENV_KEYS = (
    "DASHSCOPE_API_KEY",
    "TELEGRAM_BOT_TOKEN",
    "TELEGRAM_CHAT_ID",
    "SLACK_APP_TOKEN",
    "SLACK_BOT_TOKEN",
)


@dataclass(frozen=True)
class BrainCandidate:
    name: str
    command: str
    installed: bool
    logged_in: bool
    detail: str

    @property
    def ready(self) -> bool:
        return self.installed and self.logged_in


def parse_args(argv: list[str] | None = None) -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        prog="jc-setup",
        description="Configure a JC instance: brain, first channel, first verified chat.",
    )
    parser.add_argument("path", nargs="?", default=".", help="instance directory")
    parser.add_argument("--defaults", action="store_true", help="non-interactive defaults")
    parser.add_argument("--force", action="store_true", help="overwrite generated bootstrap files")
    parser.add_argument("--start", action="store_true", help="start gateway daemon after setup")
    parser.add_argument("--no-start", action="store_true", help="do not start gateway daemon")
    parser.add_argument("--install-watchdog", action="store_true", help="install watchdog cron entries")
    parser.add_argument("--no-watchdog", action="store_true", help="do not install watchdog cron entries")
    parser.add_argument(
        "--no-wait",
        action="store_true",
        help="configure without waiting for the first Telegram message",
    )
    parser.add_argument(
        "--channel",
        default="telegram",
        choices=["telegram"],
        help="first communication channel; currently telegram",
    )
    return parser.parse_args(argv)


def run(cmd: list[str], *, input_text: str | None = None, timeout: int = 15) -> subprocess.CompletedProcess[str]:
    return subprocess.run(
        cmd,
        input=input_text,
        capture_output=True,
        text=True,
        timeout=timeout,
    )


def prompt(label: str, default: str = "", *, secret: bool = False, defaults: bool = False) -> str:
    if defaults:
        return default
    suffix = " [keep existing]" if secret and default else (f" [{default}]" if default else "")
    if secret:
        import getpass

        if sys.stdin.isatty():
            value = getpass.getpass(f"{label}{suffix}: ")
        else:
            print(f"{label}{suffix}: ", end="", file=sys.stderr)
            value = sys.stdin.readline()
    else:
        value = input(f"{label}{suffix}: ")
    return value.strip() or default


def yesno(label: str, default: str = "no", *, defaults: bool = False) -> bool:
    if defaults:
        return default.lower() in {"y", "yes", "true", "1"}
    while True:
        value = input(f"{label} [{default}]: ").strip().lower() or default.lower()
        if value in {"y", "yes", "true", "1"}:
            return True
        if value in {"n", "no", "false", "0"}:
            return False
        print("Please answer yes or no.", file=sys.stderr)


def init_instance(target: Path) -> bool:
    target.mkdir(parents=True, exist_ok=True)
    if (target / ".jc").exists():
        print("==> Existing JC instance detected; configuring in place.")
        return True
    proc = run([str(ROOT / "bin" / "jc-init"), str(target)], timeout=60)
    if proc.returncode != 0:
        print(proc.stdout, end="")
        print(proc.stderr, end="", file=sys.stderr)
        raise SystemExit(proc.returncode)
    print(proc.stdout, end="")
    return False


def read_env(path: Path) -> dict[str, str]:
    values: dict[str, str] = {}
    if not path.exists():
        return values
    for line in path.read_text(encoding="utf-8", errors="replace").splitlines():
        stripped = line.strip()
        if not stripped or stripped.startswith("#") or "=" not in stripped:
            continue
        key, raw = stripped.split("=", 1)
        raw = raw.strip()
        if (raw.startswith("'") and raw.endswith("'")) or (raw.startswith('"') and raw.endswith('"')):
            raw = raw[1:-1]
        values[key] = raw
    for key in ENV_KEYS:
        if not values.get(key) and os.environ.get(key):
            values[key] = os.environ[key]
    return values


def shell_quote(value: str) -> str:
    return "'" + value.replace("'", "'\\''") + "'"


def write_env(target: Path, updates: dict[str, str]) -> None:
    current = read_env(target / ".env")
    current.update({k: v for k, v in updates.items() if v is not None})
    lines = ["# JuliusCaesar instance secrets. Do not commit."]
    for key in ENV_KEYS:
        lines.append(f"{key}={shell_quote(current.get(key, ''))}")
    tmp = target / ".env.tmp"
    old_umask = os.umask(0o077)
    try:
        tmp.write_text("\n".join(lines) + "\n", encoding="utf-8")
    finally:
        os.umask(old_umask)
    os.replace(tmp, target / ".env")
    os.chmod(target / ".env", 0o600)


def _probe(command: list[str]) -> tuple[bool, str]:
    try:
        proc = run(command, timeout=6)
    except (OSError, subprocess.TimeoutExpired) as exc:
        return False, str(exc)
    text = (proc.stdout or proc.stderr or "").strip().splitlines()
    detail = text[0][:120] if text else f"exit {proc.returncode}"
    return proc.returncode == 0, detail


def detect_brain(name: str) -> BrainCandidate:
    command = name
    installed = shutil.which(command) is not None
    if not installed:
        return BrainCandidate(name, command, False, False, "not on PATH")
    if name == "codex":
        auth_file = Path.home() / ".codex" / "auth.json"
        if auth_file.exists():
            return BrainCandidate(name, command, True, True, "auth.json present")
    probes = {
        "claude": [["claude", "auth", "status"], ["claude", "whoami"], ["claude", "--version"]],
        "codex": [["codex", "auth", "status"], ["codex", "--version"]],
        "gemini": [["gemini", "auth", "status"], ["gemini", "--version"]],
        "opencode": [["opencode", "auth", "status"], ["opencode", "--version"]],
        "aider": [["aider", "--version"]],
    }[name]
    last = ""
    for probe in probes:
        ok, detail = _probe(probe)
        last = detail
        if ok:
            return BrainCandidate(name, command, True, True, detail)
    return BrainCandidate(name, command, True, False, last or "login probe failed")


def detect_brains() -> list[BrainCandidate]:
    override = os.environ.get("JC_SETUP_ASSUME_BRAINS", "").strip()
    if override:
        names = [n.strip() for n in override.split(",") if n.strip()]
        return [
            BrainCandidate(name, name, True, True, "assumed ready by JC_SETUP_ASSUME_BRAINS")
            for name in names
            if name in SUPPORTED_BRAINS
        ]
    return [detect_brain(name) for name in SUPPORTED_BRAINS]


def choose_brain(candidates: list[BrainCandidate], *, defaults: bool) -> str:
    ready = [c for c in candidates if c.ready]
    print("\n==> Coding tools")
    for candidate in candidates:
        state = "ready" if candidate.ready else ("installed, not logged in" if candidate.installed else "missing")
        print(f"  {candidate.name:<9} {state:<24} {candidate.detail}")
    if not ready:
        print("\nNo logged-in coding tool is available. Log in to Claude, Codex, Gemini, OpenCode, or Aider and rerun setup.", file=sys.stderr)
        raise SystemExit(1)
    if defaults or len(ready) == 1:
        chosen = ready[0].name
        print(f"Selected brain: {chosen}")
        return chosen
    while True:
        value = input(f"Select brain [{ready[0].name}]: ").strip() or ready[0].name
        if value in {c.name for c in ready}:
            return value
        print("Choose one of: " + ", ".join(c.name for c in ready), file=sys.stderr)


def write_gateway_config(target: Path, brain: str, telegram_token: str, chat_id: str) -> None:
    text = render_default_config(
        default_brain=brain,
        telegram_enabled=bool(telegram_token),
        telegram_chat_id=chat_id,
        slack_enabled=False,
    )
    path = target / "ops" / "gateway.yaml"
    path.parent.mkdir(parents=True, exist_ok=True)
    atomic_write_text(path, text)


def ensure_memory_bootstrap(target: Path, brain: str, *, force: bool) -> None:
    l1 = target / "memory" / "L1"
    l1.mkdir(parents=True, exist_ok=True)
    today = datetime.now(timezone.utc).strftime("%Y-%m-%d")
    files = {
        "IDENTITY.md": f"""---
slug: IDENTITY
title: Identity
layer: L1
type: identity
state: draft
created: {today}
updated: {today}
last_verified: "{today}"
tags: [identity, bootstrap]
links: [USER, RULES]
---

# Identity

Bootstrap in progress. The selected brain is `{brain}`.

The assistant should interview the operator one question at a time, then help
turn the answers into durable memory updates for IDENTITY, USER, RULES, and HOT.
""",
        "USER.md": f"""---
slug: USER
title: User profile
layer: L1
type: user
state: draft
created: {today}
updated: {today}
last_verified: "{today}"
tags: [user, bootstrap]
links: [IDENTITY, RULES]
---

# User profile

Bootstrap in progress. Ask the operator for their name, timezone, preferences,
current work, and standing expectations.
""",
        "RULES.md": f"""---
slug: RULES
title: Standing Rules & Feedback
layer: L1
type: rules
state: draft
created: {today}
updated: {today}
last_verified: "{today}"
tags: [rules, bootstrap]
links: [IDENTITY, USER]
---

# Standing rules

Bootstrap in progress. Capture operator rules only after explicit confirmation.
""",
        "HOT.md": f"""---
slug: HOT
title: Hot Cache
layer: L1
type: hot
state: draft
created: {today}
updated: {today}
last_verified: "{today}"
tags: [hot, bootstrap]
links: [IDENTITY, USER, RULES]
---

# Hot cache

Bootstrap just completed setup. First channel is Telegram.
""",
    }
    for name, content in files.items():
        path = l1 / name
        if force or not path.exists():
            path.write_text(content, encoding="utf-8")


def telegram_api(token: str, method: str, payload: dict[str, Any], *, timeout: int = 20) -> dict[str, Any]:
    data = urllib.parse.urlencode(payload).encode("utf-8")
    url = f"https://api.telegram.org/bot{token}/{method}"
    with urllib.request.urlopen(url, data=data, timeout=timeout) as response:  # noqa: S310
        raw = response.read().decode("utf-8")
    parsed = json.loads(raw)
    if not parsed.get("ok"):
        raise RuntimeError(parsed.get("description") or raw)
    return parsed


def latest_update_id(token: str) -> int:
    try:
        parsed = telegram_api(token, "getUpdates", {"timeout": 0, "limit": 1}, timeout=10)
    except Exception:
        return 0
    updates = parsed.get("result") or []
    if not updates:
        return 0
    return int(updates[-1].get("update_id", 0))


def wait_for_first_telegram_message(token: str, *, timeout_seconds: int = 300) -> tuple[str, str]:
    bot = telegram_api(token, "getMe", {}, timeout=10)["result"]
    username = bot.get("username") or bot.get("first_name") or "your bot"
    print(f"\nSend the first message to @{username}. Waiting for it now.")
    offset = latest_update_id(token) + 1
    deadline = time.monotonic() + timeout_seconds
    while time.monotonic() < deadline:
        parsed = telegram_api(
            token,
            "getUpdates",
            {"timeout": 10, "limit": 10, "offset": offset, "allowed_updates": json.dumps(["message"])},
            timeout=15,
        )
        for update in parsed.get("result") or []:
            offset = int(update.get("update_id", offset)) + 1
            message = update.get("message") or {}
            chat = message.get("chat") or {}
            chat_id = chat.get("id")
            if chat_id is not None:
                text = str(message.get("text") or "").strip()
                return str(chat_id), text
    raise TimeoutError("timed out waiting for first Telegram message")


def generate_first_question(brain: str) -> str:
    prompt_text = (
        "You are starting a guided onboarding conversation for a new "
        "JuliusCaesar assistant. Ask exactly one friendly, high-value first "
        "question that will help define the assistant identity. Keep it under "
        "45 words."
    )
    if os.environ.get("JC_SETUP_SKIP_AI_PROMPT"):
        return fallback_first_question()
    commands = {
        "claude": ["claude", "-p", prompt_text],
        "gemini": ["gemini", prompt_text],
        "opencode": ["opencode", "run", prompt_text],
    }
    cmd = commands.get(brain)
    if cmd:
        try:
            proc = run(cmd, timeout=30)
            if proc.returncode == 0 and proc.stdout.strip():
                return proc.stdout.strip().splitlines()[0]
        except Exception:
            pass
    return fallback_first_question()


def fallback_first_question() -> str:
    return (
        "I’m ready to build this agent with you. First question: what should "
        "this assistant be responsible for, and what would make it genuinely useful?"
    )


def send_telegram_message(token: str, chat_id: str, text: str) -> None:
    telegram_api(token, "sendMessage", {"chat_id": chat_id, "text": text}, timeout=15)


def write_watchdog_conf(target: Path, *, force: bool) -> None:
    path = target / "ops" / "watchdog.conf"
    if path.exists() and not force:
        return
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(
        """# Watchdog configuration for this JuliusCaesar instance.
RUNTIME_MODE=gateway
SESSION_ID=
SCREEN_NAME=jc-assistant
CLAUDE_ARGS_EXTRA="--dangerously-skip-permissions --chrome --channels plugin:telegram@claude-plugins-official"
""",
        encoding="utf-8",
    )


def rebuild_memory(target: Path) -> None:
    proc = run([str(ROOT / "bin" / "jc-memory"), "--instance-dir", str(target), "rebuild"], timeout=60)
    if proc.returncode != 0:
        print(proc.stderr, file=sys.stderr)
        raise SystemExit(proc.returncode)


def main(argv: list[str] | None = None) -> int:
    args = parse_args(argv)
    target = Path(args.path).expanduser().resolve()

    if args.start and args.no_start:
        raise SystemExit("--start conflicts with --no-start")
    if args.install_watchdog and args.no_watchdog:
        raise SystemExit("--install-watchdog conflicts with --no-watchdog")

    print("==> JuliusCaesar guided setup")
    print(f"Target: {target}")
    existing = init_instance(target)

    candidates = detect_brains()
    brain = choose_brain(candidates, defaults=args.defaults)

    env = read_env(target / ".env")
    telegram_token = prompt(
        "Telegram bot token for the first channel",
        env.get("TELEGRAM_BOT_TOKEN", ""),
        secret=True,
        defaults=args.defaults,
    )
    if not telegram_token:
        raise SystemExit("A Telegram bot token is required for the first communication channel.")

    chat_id = env.get("TELEGRAM_CHAT_ID", "")
    first_text = ""
    if not args.no_wait:
        try:
            chat_id, first_text = wait_for_first_telegram_message(telegram_token)
            print(f"Authorized first chat: {chat_id}")
        except Exception as exc:
            raise SystemExit(f"Could not verify first Telegram message: {exc}") from exc
    elif not chat_id:
        chat_id = prompt("Telegram chat id", "", defaults=args.defaults)

    updates = {"TELEGRAM_BOT_TOKEN": telegram_token, "TELEGRAM_CHAT_ID": chat_id}
    write_env(target, updates)
    write_gateway_config(target, brain, telegram_token, chat_id)
    ensure_memory_bootstrap(target, brain, force=args.force or not existing)
    write_watchdog_conf(target, force=args.force)
    (target / "state" / "setup").mkdir(parents=True, exist_ok=True)
    (target / "state" / "setup" / "first-message.json").write_text(
        json.dumps(
            {"chat_id": chat_id, "message": first_text, "brain": brain, "channel": "telegram"},
            indent=2,
        ),
        encoding="utf-8",
    )

    rebuild_memory(target)

    question = generate_first_question(brain)
    if chat_id and not args.no_wait:
        send_telegram_message(telegram_token, chat_id, question)
        print("Sent the first onboarding question to Telegram.")
    else:
        print("\nFirst onboarding question:")
        print(question)

    if args.start:
        run([str(ROOT / "bin" / "jc-gateway"), "--instance-dir", str(target), "start"], timeout=30)
    if args.install_watchdog:
        run([str(ROOT / "bin" / "jc-watchdog"), "--instance-dir", str(target), "install"], timeout=30)

    print("\nSetup complete.")
    print(f"Instance: {target}")
    print("Next: answer the Telegram question. The selected brain will drive agent creation from there.")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
