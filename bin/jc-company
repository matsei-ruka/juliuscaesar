#!/usr/bin/env python3
"""jc-company — Company observability client CLI for JuliusCaesar.

Subcommands: register, status, alert, approval, replay.
See ``lib/company/cli.py`` for argument details, ``docs/specs/the-company.md``
for the integration spec.
"""

from __future__ import annotations

import sys
from pathlib import Path

_HERE = Path(__file__).resolve().parent
_LIB = _HERE.parent / "lib"
if _LIB.exists() and str(_LIB) not in sys.path:
    sys.path.insert(0, str(_LIB))

from company.cli import main  # type: ignore  # noqa: E402


if __name__ == "__main__":
    sys.exit(main())
