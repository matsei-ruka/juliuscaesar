#!/usr/bin/env python3
"""jc-chats — list / show / prune the chat directory.

Subcommands:
  list   Tabular listing, ordered by last_seen DESC.
  show   Full row dump for a single chat.
  prune  Delete rows whose last_seen is older than a threshold.

Instance dir resolution mirrors `jc-memory` and `jc-workers`.
"""

from __future__ import annotations

import argparse
import json
import sys
from pathlib import Path

_HERE = Path(__file__).resolve().parent
_LIB = _HERE.parent / "lib"
if _LIB.exists() and str(_LIB) not in sys.path:
    sys.path.insert(0, str(_LIB))

from gateway import chats  # type: ignore  # noqa: E402
from gateway.channels import email_dispatcher as _email_dispatcher  # type: ignore  # noqa: E402
from gateway.config import load_config  # type: ignore  # noqa: E402
from gateway.config_writer import (  # type: ignore  # noqa: E402
    env_chat_ids,
    update_env_chat_ids,
    update_gateway_yaml_chat_lists,
)
from jc_paths import InstanceResolutionError, resolve_instance_dir as _resolve_instance_dir  # type: ignore  # noqa: E402


def resolve_instance_dir(arg: str | None) -> Path:
    try:
        return _resolve_instance_dir(arg, fallback_markers=("memory",))
    except InstanceResolutionError as exc:
        raise SystemExit(str(exc)) from exc


def _parse_older_than(value: str) -> int:
    """Parse `--older-than` like `90d`, `30d`, or a bare integer (days)."""
    s = value.strip().lower()
    if s.endswith("d"):
        s = s[:-1]
    try:
        return int(s)
    except ValueError as exc:
        raise SystemExit(f"--older-than must be days (e.g. 90 or 90d): {value}") from exc


def cmd_list(args: argparse.Namespace) -> int:
    instance = resolve_instance_dir(args.instance_dir)
    rows = chats.list_chats(
        instance,
        channel=args.channel,
        limit=args.limit,
        auth_status=args.auth_status,
    )
    if args.json:
        print(json.dumps([c.to_dict() for c in rows], indent=2))
        return 0
    if not rows:
        print("(no chats)")
        return 0

    def _trunc(s: str, width: int) -> str:
        return s if len(s) <= width else s[: width - 1] + "…"

    print(
        f"{'CHAT_ID':<14}  {'TYPE':<10}  {'AUTH':<8}  {'TITLE':<26}  "
        f"{'MEMBERS':>7}  {'LAST_SEEN':<19}"
    )
    print("-" * 96)
    for c in rows:
        last = (c.last_seen or "")[:19]
        members = str(c.member_count) if c.member_count is not None else "-"
        print(
            f"{_trunc(c.chat_id, 14):<14}  "
            f"{(c.chat_type or '?'):<10}  "
            f"{(c.auth_status or '-'):<8}  "
            f"{_trunc(c.title or '-', 26):<26}  "
            f"{members:>7}  "
            f"{last:<19}"
        )
    return 0


def _config_authority(instance: Path, channel: str) -> tuple[set[str], set[str]]:
    """Read `(allowed, blocked)` chat-id sets from yaml + env."""
    cfg = load_config(instance).channel(channel)
    allowed = set(cfg.chat_ids)
    blocked = set(cfg.blocked_chat_ids)
    if channel == "telegram":
        allowed |= set(env_chat_ids(instance))
    return allowed, blocked


def cmd_approve(args: argparse.Namespace) -> int:
    """Approve a chat_id (telegram-style) or a sender email address.

    `--email <addr>` routes to the email-channel allowlist in
    `ops/gateway.yaml` (`channels.email.senders.allowed`), drains any
    pending messages from that sender into the gateway queue, and
    notifies Telegram. Otherwise behaves as the original chat_id flow.
    """
    instance = resolve_instance_dir(args.instance_dir)
    if args.email:
        return _approve_email(instance, args.email)
    if not args.chat_id:
        raise SystemExit("approve: provide a chat_id or --email <addr>")
    allowed, blocked = _config_authority(instance, args.channel)
    if args.chat_id in allowed:
        print(f"chat {args.chat_id} already approved (no-op)")
        return 0
    yaml_changed = update_gateway_yaml_chat_lists(
        instance,
        channel=args.channel,
        allow_add=[args.chat_id],
        block_remove=[args.chat_id],
    )
    env_changed = False
    if args.channel == "telegram":
        env_changed = update_env_chat_ids(instance, add=[args.chat_id])
    if yaml_changed:
        print(f"ops/gateway.yaml updated (+chat_ids: {args.chat_id})")
    if env_changed:
        print(f".env updated (+TELEGRAM_CHAT_IDS: {args.chat_id})")
    if args.chat_id in blocked:
        print(f"chat {args.chat_id} removed from blocked_chat_ids")
    return 0


def cmd_deny(args: argparse.Namespace) -> int:
    """Deny a chat_id (telegram-style) or a sender email address.

    `--email <addr>` routes to `channels.email.senders.blocklist` in
    `ops/gateway.yaml`, drops any pending messages from that sender,
    and notifies Telegram.
    """
    instance = resolve_instance_dir(args.instance_dir)
    if args.email:
        return _deny_email(instance, args.email)
    if not args.chat_id:
        raise SystemExit("deny: provide a chat_id or --email <addr>")
    _allowed, blocked = _config_authority(instance, args.channel)
    if args.chat_id in blocked:
        print(f"chat {args.chat_id} already blocked (no-op)")
        return 0
    yaml_changed = update_gateway_yaml_chat_lists(
        instance,
        channel=args.channel,
        block_add=[args.chat_id],
        allow_remove=[args.chat_id],
    )
    env_changed = False
    if args.channel == "telegram":
        env_changed = update_env_chat_ids(instance, remove=[args.chat_id])
    if yaml_changed:
        print(f"ops/gateway.yaml updated (+blocked_chat_ids: {args.chat_id})")
    if env_changed:
        print(f".env updated (-TELEGRAM_CHAT_IDS: {args.chat_id})")
    print(
        "note: bot will leave the chat on the next live update; "
        "for an immediate leave, run `jc chats deny --leave-now <chat_id>`"
    )
    return 0


def _email_senders(instance: Path) -> tuple[set[str], set[str]]:
    """Read `(allowed, blocked)` sender sets from `channels.email.senders`."""
    import yaml as _yaml
    cfg_path = instance / "ops" / "gateway.yaml"
    if not cfg_path.exists():
        return set(), set()
    try:
        data = _yaml.safe_load(cfg_path.read_text(encoding="utf-8")) or {}
    except _yaml.YAMLError:
        return set(), set()
    senders = ((data.get("channels") or {}).get("email") or {}).get("senders") or {}
    allowed = {str(s).lower() for s in (senders.get("allowed") or [])}
    blocked = {str(s).lower() for s in (senders.get("blocklist") or [])}
    return allowed, blocked


def _update_email_sender_list(
    instance: Path,
    *,
    allow_add: list[str] | None = None,
    block_add: list[str] | None = None,
) -> bool:
    """Idempotently add a sender to the email allowlist or blocklist.

    Removes the sender from the opposite list if present (so a previously
    denied sender can be re-approved without manual yaml editing).
    """
    import yaml as _yaml
    from gateway.config_writer import atomic_write_text

    cfg_path = instance / "ops" / "gateway.yaml"
    cfg_path.parent.mkdir(parents=True, exist_ok=True)
    text = cfg_path.read_text(encoding="utf-8") if cfg_path.exists() else ""
    data = _yaml.safe_load(text) if text else {}
    if not isinstance(data, dict):
        data = {}

    channels = data.setdefault("channels", {})
    if not isinstance(channels, dict):
        channels = {}
        data["channels"] = channels
    email = channels.setdefault("email", {})
    if not isinstance(email, dict):
        email = {}
        channels["email"] = email
    senders = email.setdefault("senders", {})
    if not isinstance(senders, dict):
        senders = {}
        email["senders"] = senders
    allowed = list(senders.get("allowed") or [])
    blocked = list(senders.get("blocklist") or [])

    changed = False
    for s in allow_add or []:
        s_norm = s.lower().strip()
        if s_norm and s_norm not in (a.lower() for a in allowed):
            allowed.append(s_norm)
            changed = True
        # Remove from blocklist if present.
        new_blocked = [b for b in blocked if b.lower() != s_norm]
        if new_blocked != blocked:
            blocked = new_blocked
            changed = True
    for s in block_add or []:
        s_norm = s.lower().strip()
        if s_norm and s_norm not in (b.lower() for b in blocked):
            blocked.append(s_norm)
            changed = True
        new_allowed = [a for a in allowed if a.lower() != s_norm]
        if new_allowed != allowed:
            allowed = new_allowed
            changed = True

    if not changed:
        return False

    senders["allowed"] = sorted(allowed)
    if blocked:
        senders["blocklist"] = sorted(blocked)
    elif "blocklist" in senders:
        del senders["blocklist"]

    new_text = _yaml.safe_dump(data, default_flow_style=False, sort_keys=False, allow_unicode=True)
    if new_text == text:
        return False
    atomic_write_text(cfg_path, new_text)
    return True


def _notify_telegram_decision(instance: Path, body: str) -> None:
    """Best-effort Telegram confirmation. No-op if sender unavailable."""
    import os as _os
    import subprocess as _sp

    sender = Path(__file__).resolve().parent.parent / "lib" / "heartbeat" / "lib" / "send_telegram.py"
    if not sender.exists():
        return
    env = _os.environ.copy()
    env["JC_INSTANCE_DIR"] = str(instance)
    try:
        _sp.run(
            [sys.executable, str(sender)],
            input=body,
            capture_output=True,
            text=True,
            env=env,
            timeout=15,
            check=False,
        )
    except Exception:  # noqa: BLE001
        pass


def _approve_email(instance: Path, email_addr: str) -> int:
    addr = email_addr.lower().strip()
    allowed, _blocked = _email_senders(instance)
    if addr in allowed:
        print(f"sender {addr} already on email allowlist (no-op)")
        return 0
    changed = _update_email_sender_list(instance, allow_add=[addr])
    if changed:
        print(f"ops/gateway.yaml updated (+channels.email.senders.allowed: {addr})")
    drained = _email_dispatcher.drain_pending(instance, addr, action="approve")
    if drained:
        print(f"drained {drained} pending message(s) from {addr} → gateway queue")
    _notify_telegram_decision(
        instance,
        f"✅ Email sender approved: `{addr}`\n"
        + (f"Drained {drained} pending message(s) into the queue." if drained else "No pending messages."),
    )
    return 0


def _deny_email(instance: Path, email_addr: str) -> int:
    addr = email_addr.lower().strip()
    _allowed, blocked = _email_senders(instance)
    if addr in blocked:
        print(f"sender {addr} already on email blocklist (no-op)")
        return 0
    changed = _update_email_sender_list(instance, block_add=[addr])
    if changed:
        print(f"ops/gateway.yaml updated (+channels.email.senders.blocklist: {addr})")
    dropped = _email_dispatcher.drain_pending(instance, addr, action="deny")
    if dropped:
        print(f"dropped {dropped} pending message(s) from {addr}")
    _notify_telegram_decision(
        instance,
        f"⛔ Email sender denied: `{addr}`\n"
        + (f"Dropped {dropped} pending message(s)." if dropped else ""),
    )
    return 0


def cmd_migrate_to_config(args: argparse.Namespace) -> int:
    """Lift DB `auth_status` rows into yaml + .env config.

    One-shot helper for instances created before the config-only
    refactor (PR feat/sender-approval-config-only). Idempotent: any
    chat already in config is skipped. DB rows are left untouched —
    `auth_status` becomes informational from this point on.
    """
    instance = resolve_instance_dir(args.instance_dir)
    rows = chats.list_chats(instance, channel=args.channel)
    allowed, blocked = _config_authority(instance, args.channel)
    to_allow = sorted(
        c.chat_id for c in rows
        if c.auth_status == "allowed" and c.chat_id not in allowed
    )
    to_block = sorted(
        c.chat_id for c in rows
        if c.auth_status == "denied" and c.chat_id not in blocked
    )
    if not to_allow and not to_block:
        print("(nothing to migrate; config already in sync with DB)")
        return 0
    if args.dry_run:
        if to_allow:
            print(f"would add to chat_ids: {to_allow}")
        if to_block:
            print(f"would add to blocked_chat_ids: {to_block}")
        print("re-run without --dry-run to apply.")
        return 0
    yaml_changed = update_gateway_yaml_chat_lists(
        instance,
        channel=args.channel,
        allow_add=to_allow,
        block_add=to_block,
    )
    env_changed = False
    if args.channel == "telegram" and to_allow:
        env_changed = update_env_chat_ids(instance, add=to_allow)
    if yaml_changed:
        print(f"ops/gateway.yaml updated (+{len(to_allow)} allowed, "
              f"+{len(to_block)} blocked)")
    if env_changed:
        print(f".env updated (+{len(to_allow)} TELEGRAM_CHAT_IDS)")
    return 0


def cmd_show(args: argparse.Namespace) -> int:
    instance = resolve_instance_dir(args.instance_dir)
    chat = chats.get_chat(instance, channel=args.channel, chat_id=args.chat_id)
    if chat is None:
        raise SystemExit(
            f"chat not found: channel={args.channel} chat_id={args.chat_id}"
        )
    if args.json:
        print(json.dumps(chat.to_dict(), indent=2))
        return 0
    print(f"chat {chat.chat_id} [{chat.chat_type or '?'}]")
    print(f"  channel          {chat.channel}")
    print(f"  title            {chat.title or '-'}")
    print(f"  username         {('@' + chat.username) if chat.username else '-'}")
    print(
        f"  member_count     "
        f"{chat.member_count if chat.member_count is not None else '-'}"
    )
    print(f"  first_seen       {chat.first_seen}")
    print(f"  last_seen        {chat.last_seen}")
    print(f"  last_message_id  {chat.last_message_id or '-'}")
    return 0


def cmd_prune(args: argparse.Namespace) -> int:
    instance = resolve_instance_dir(args.instance_dir)
    days = _parse_older_than(args.older_than)
    if days <= 0:
        raise SystemExit("--older-than must be positive")
    if not args.yes:
        # Read-only preview before destructive op.
        rows = chats.list_chats(instance, channel=args.channel)
        from datetime import datetime, timedelta, timezone

        cutoff = (
            datetime.now(timezone.utc) - timedelta(days=days)
        ).strftime("%Y-%m-%dT%H:%M:%SZ")
        candidates = [c for c in rows if (c.last_seen or "") < cutoff]
        if not candidates:
            print(f"(no chats older than {days}d)")
            return 0
        print(f"would delete {len(candidates)} chat(s) older than {days}d:")
        for c in candidates:
            print(f"  {c.chat_id} | {c.chat_type or '?'} | {c.title or '-'} "
                  f"(last {c.last_seen})")
        print("re-run with --yes to confirm.")
        return 0
    removed = chats.prune_chats(
        instance,
        older_than_days=days,
        channel=args.channel,
    )
    print(f"removed {removed} chat(s) older than {days}d")
    return 0


def build_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(prog="jc-chats")
    p.add_argument("--instance-dir", help="override instance dir")
    sub = p.add_subparsers(dest="cmd", required=True)

    pl = sub.add_parser("list", help="list chats by last_seen")
    pl.add_argument("--channel", default=None, help="filter by channel (e.g. telegram)")
    pl.add_argument("--limit", type=int, default=20)
    pl.add_argument(
        "--auth-status",
        default=None,
        choices=["allowed", "pending", "denied"],
        help="filter by auth_status",
    )
    pl.add_argument("--json", action="store_true")
    pl.set_defaults(func=cmd_list)

    pa = sub.add_parser(
        "approve",
        help="approve a chat_id or (with --email) an email sender",
    )
    pa.add_argument("chat_id", nargs="?", default=None)
    pa.add_argument("--channel", default="telegram")
    pa.add_argument(
        "--email",
        default=None,
        help="approve an email sender (writes channels.email.senders.allowed)",
    )
    pa.set_defaults(func=cmd_approve)

    pd = sub.add_parser(
        "deny",
        help="deny a chat_id or (with --email) an email sender",
    )
    pd.add_argument("chat_id", nargs="?", default=None)
    pd.add_argument("--channel", default="telegram")
    pd.add_argument(
        "--email",
        default=None,
        help="deny an email sender (writes channels.email.senders.blocklist)",
    )
    pd.set_defaults(func=cmd_deny)

    ps = sub.add_parser("show", help="show one chat's full row")
    ps.add_argument("chat_id")
    ps.add_argument("--channel", default="telegram")
    ps.add_argument("--json", action="store_true")
    ps.set_defaults(func=cmd_show)

    pm = sub.add_parser(
        "migrate-to-config",
        help="lift DB-approved/denied rows into ops/gateway.yaml + .env",
    )
    pm.add_argument("--channel", default="telegram")
    pm.add_argument("--dry-run", action="store_true")
    pm.set_defaults(func=cmd_migrate_to_config)

    pp = sub.add_parser("prune", help="delete chats older than threshold")
    pp.add_argument(
        "--older-than",
        required=True,
        help="age threshold (days, e.g. 90 or 90d)",
    )
    pp.add_argument("--channel", default=None, help="restrict to one channel")
    pp.add_argument("--yes", action="store_true", help="skip confirmation")
    pp.set_defaults(func=cmd_prune)

    return p


def main() -> int:
    args = build_parser().parse_args()
    return args.func(args)


if __name__ == "__main__":
    sys.exit(main())
