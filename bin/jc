#!/usr/bin/env bash
# jc — JuliusCaesar CLI router. Dispatches to jc-<subcommand> binaries.
#
# Usage:
#   jc <subcommand> <args...>
#
# Known subcommands:
#   memory       Knowledge base (llm-wiki + FTS5).
#   heartbeat    Run scheduled tasks.
#   voice        TTS / ASR / voice enrollment.
#   watchdog     Supervisor for the instance's live claude session.
#   workers      On-demand background agents.
#   chats        Telegram chat directory.
#   email        Email channel operations.
#   transcripts  Per-conversation chat transcripts (read/tail/search).
#   gateway      Durable event queue and gateway runtime.
#   company      Fleet observability client (The Company).
#   init         Scaffold a new instance from templates.
#   setup        Guided first-run configurator.
#   update       Check and apply framework updates.
#   completion   Print shell completion scripts.
#   self-model   Autonomous self-observation loop (proposes RULES/IDENTITY/JOURNAL edits).
#
# All subcommands accept `--instance-dir <path>` and respect `$JC_INSTANCE_DIR`.

set -euo pipefail

VERSION="2026.04.28"

usage() {
    cat <<EOF
jc — JuliusCaesar CLI router ($VERSION)

Usage: jc <subcommand> [args...]

Subcommands:
  memory       Knowledge base (backed by jc-memory).
  heartbeat    Scheduled task runner (jc-heartbeat).
  voice        TTS / ASR / enrollment (jc-voice).
  watchdog     Live session supervisor (jc-watchdog).
  workers      On-demand background agents (jc-workers).
  chats        Telegram chat directory (jc-chats).
  email        Email channel operations (jc-email).
  transcripts  Per-conversation chat transcripts (jc-transcripts).
  gateway      Durable event queue and gateway runtime (jc-gateway).
  company      Fleet observability client (jc-company).
  init         Scaffold a new instance from templates.
  setup        Guided first-run configurator.
  update       Check and apply framework updates (jc-update).
  upgrade      Reconfigure an existing instance (channels, brain, triage).
  doctor       Diagnose the instance + environment.
  completion   Print shell completion scripts (bash/zsh).
  codex-auth   Inspect / refresh the local Codex CLI's OAuth state (jc-codex-auth).
  self-model   Autonomous self-observation loop (jc-self-model).
  migrate-to-0.3  Bootstrap an existing 0.2.x instance for the unified gateway.

Global flags:
  --instance-dir <path>    Override instance dir (or set \$JC_INSTANCE_DIR).

Examples:
  jc init ~/my-new-instance
  jc setup ~/my-new-instance
  jc memory search "query"
  jc heartbeat run morning_briefing
  jc voice speak "hello world"
  jc watchdog status
EOF
}

if [[ $# -eq 0 ]]; then
    usage; exit 0
fi

GLOBAL_ARGS=()
while (( $# )); do
    case "$1" in
        --instance-dir)
            if [[ $# -lt 2 ]]; then
                echo "--instance-dir requires a path" >&2
                exit 2
            fi
            GLOBAL_ARGS+=("$1" "$2")
            shift 2
            ;;
        --instance-dir=*)
            GLOBAL_ARGS+=("$1")
            shift
            ;;
        *)
            break
            ;;
    esac
done

if [[ $# -eq 0 ]]; then
    usage; exit 0
fi

SUB="$1"; shift

case "$SUB" in
    -h|--help|help)
        usage; exit 0
        ;;
    -v|--version|version)
        echo "juliuscaesar $VERSION"; exit 0
        ;;
    memory|heartbeat|voice|watchdog|workers|chats|email|transcripts|gateway|company|init|setup|update|doctor|upgrade|user-model|codex-auth|self-model|migrate-to-0.3|completion)
        if ! command -v "jc-$SUB" >/dev/null 2>&1; then
            echo "jc-$SUB not found on PATH. Run juliuscaesar/install.sh to set up the shims." >&2
            exit 127
        fi
        if (( ${#GLOBAL_ARGS[@]} )); then
            exec "jc-$SUB" "${GLOBAL_ARGS[@]}" "$@"
        else
            exec "jc-$SUB" "$@"
        fi
        ;;
    *)
        echo "Unknown subcommand: $SUB" >&2
        echo "Run 'jc help' for a list." >&2
        exit 2
        ;;
esac
