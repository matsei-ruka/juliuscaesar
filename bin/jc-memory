#!/usr/bin/env python3
"""jc-memory — JuliusCaesar memory CLI.

Subcommands:
  new       Create a new entry (L1 or L2).
  write     Upsert body for a slug (stdin or --body-file).
  read      Print an entry by slug (marks last_accessed).
  search    FTS5 ranked search; prints slug + snippet.
  link      Add a [[to-slug]] wikilink to an entry (idempotent, appends to body).
  lint      Broken wikilinks, orphans, stale entries.
  log       Tail memory/LOG.md.
  rebuild   Re-scan .md files and sync DB + memory/INDEX.md.
  consolidate   Placeholder for auto-dream.

Instance dir resolution (in order):
  1. --instance-dir <path> flag
  2. $JC_INSTANCE_DIR env var
  3. Walk up from cwd looking for a .jc marker file
  4. cwd

Conventions:
  slug = "<type-dir>/<slug-name>" for L2 (e.g. people/martina), or "<name>" for L1.
  Path resolution:
    L1 entries → <instance>/memory/L1/<slug>.md
    L2 entries → <instance>/memory/L2/<slug>.md
"""

from __future__ import annotations

import argparse
import sys
from datetime import date, datetime
from pathlib import Path

# Allow running directly from a clone without install.
_HERE = Path(__file__).resolve().parent
_LIB = _HERE.parent / "lib"
if _LIB.exists() and str(_LIB) not in sys.path:
    sys.path.insert(0, str(_LIB))

from memory import (  # type: ignore  # noqa: E402
    backlinks_for,
    connect,
    get,
    memory_dir,
    parse_markdown,
    rebuild,
    search,
    touch_accessed,
    upsert,
)
from memory.db import _slug_from_path  # type: ignore  # noqa: E402
from jc_paths import InstanceResolutionError, resolve_instance_dir as _resolve_instance_dir  # type: ignore  # noqa: E402


# --- Instance resolution -----------------------------------------------------


def resolve_instance_dir(arg: str | None) -> Path:
    try:
        return _resolve_instance_dir(arg, fallback_markers=("memory",))
    except InstanceResolutionError as exc:
        raise SystemExit(str(exc)) from exc


# --- Helpers -----------------------------------------------------------------


def _today() -> str:
    return date.today().isoformat()


def _now() -> str:
    return datetime.now().isoformat(timespec="seconds")


def _path_for(instance: Path, slug: str, layer: str) -> Path:
    assert layer in ("L1", "L2")
    return instance / "memory" / layer / f"{slug}.md"


def _log(instance: Path, action: str, slug: str, note: str = "") -> None:
    log_path = instance / "memory" / "LOG.md"
    log_path.parent.mkdir(parents=True, exist_ok=True)
    if not log_path.exists():
        log_path.write_text(
            "# Memory — Operation Log\n\nAppend-only audit trail. Newest at bottom.\n\n"
            "Format: `YYYY-MM-DD HH:MM  <action>  <slug>  <note>`\n\n---\n\n",
            encoding="utf-8",
        )
    line = f"{_now()}  {action:<10}  {slug}"
    if note:
        line += f"  — {note}"
    with log_path.open("a", encoding="utf-8") as f:
        f.write(line + "\n")


def _infer_layer(slug: str) -> str:
    return "L2" if "/" in slug else "L1"


def _write_index(instance: Path) -> None:
    conn = connect(instance)
    try:
        rows = conn.execute(
            """
            SELECT slug, title, type, state, last_verified
            FROM entries
            WHERE layer = 'L2'
            ORDER BY slug
            """
        ).fetchall()
    finally:
        conn.close()

    lines = [
        "# INDEX — L2 routing table",
        "",
        "Auto-generated by `jc-memory rebuild`. Do not edit by hand — edit the entries.",
        "",
    ]
    current_dir = None
    for r in rows:
        top = r["slug"].split("/", 1)[0]
        if top != current_dir:
            current_dir = top
            lines.append("")
            lines.append(f"## {top}")
            lines.append("")
        state_mark = {
            "verified": "✓",
            "active": "·",
            "reviewed": "·",
            "draft": "?",
            "stale": "!",
            "archived": "×",
        }.get(r["state"], "·")
        lines.append(
            f"- [{state_mark}] [[{r['slug']}|{r['title']}]]  — `{r['type'] or ''}`"
        )

    (memory_dir(instance) / "INDEX.md").write_text("\n".join(lines) + "\n", encoding="utf-8")


# --- Commands ----------------------------------------------------------------


def cmd_new(args: argparse.Namespace, instance: Path) -> int:
    slug = args.slug
    layer = args.layer or _infer_layer(slug)
    path = _path_for(instance, slug, layer)
    if path.exists():
        print(f"Entry already exists: {path}", file=sys.stderr)
        return 1
    path.parent.mkdir(parents=True, exist_ok=True)
    title = args.title or slug.rsplit("/", 1)[-1].replace("-", " ").title()
    tags = args.tag or []
    links = args.link or []

    fm = [
        "---",
        f"slug: {slug}",
        f"title: {title}",
        f"layer: {layer}",
        f"type: {args.type or ''}",
        f"state: {args.state}",
        f"created: {_today()}",
        f"updated: {_today()}",
        f"last_verified: {_today() if args.state == 'verified' else ''}",
        f"tags: [{', '.join(tags)}]",
        f"links: [{', '.join(links)}]",
        "---",
        "",
        args.body or "",
        "",
    ]
    path.write_text("\n".join(fm), encoding="utf-8")

    conn = connect(instance)
    try:
        entry = parse_markdown(path, instance)
        upsert(conn, entry)
        conn.commit()
    finally:
        conn.close()

    _log(instance, "new", slug, f"layer={layer} state={args.state}")
    _write_index(instance)
    print(str(path))
    return 0


def cmd_write(args: argparse.Namespace, instance: Path) -> int:
    slug = args.slug
    layer = _infer_layer(slug)
    path = _path_for(instance, slug, layer)
    if not path.exists():
        print(f"No such entry: {path}. Use `jc-memory new` first.", file=sys.stderr)
        return 1

    if args.body_file:
        new_body = Path(args.body_file).read_text(encoding="utf-8")
    else:
        new_body = sys.stdin.read()

    text = path.read_text(encoding="utf-8")
    fm_end = text.find("\n---\n", 4) + len("\n---\n")
    head = text[:fm_end]
    head = _bump_updated(head)
    path.write_text(head + new_body.strip() + "\n", encoding="utf-8")

    conn = connect(instance)
    try:
        entry = parse_markdown(path, instance)
        upsert(conn, entry)
        conn.commit()
    finally:
        conn.close()

    _log(instance, "write", slug)
    _write_index(instance)
    return 0


def _bump_updated(frontmatter_block: str) -> str:
    lines = frontmatter_block.splitlines()
    for i, line in enumerate(lines):
        if line.startswith("updated:"):
            lines[i] = f"updated: {_today()}"
            break
    if frontmatter_block.endswith("\n"):
        return "\n".join(lines) + "\n"
    return "\n".join(lines)


def cmd_read(args: argparse.Namespace, instance: Path) -> int:
    conn = connect(instance)
    try:
        row = get(conn, args.slug)
        if not row:
            print(f"Not found: {args.slug}", file=sys.stderr)
            return 1
        path = instance / row["path"]
        touch_accessed(conn, row["slug"])
        print(path.read_text(encoding="utf-8"), end="")
        bl = backlinks_for(conn, row["slug"])
        if bl:
            print("\n\n---\n\n**Backlinks:** " + ", ".join(f"[[{s}]]" for s in bl))
    finally:
        conn.close()
    return 0


def cmd_search(args: argparse.Namespace, instance: Path) -> int:
    conn = connect(instance)
    try:
        rows = search(conn, args.query, limit=args.limit)
    finally:
        conn.close()
    if not rows:
        print("(no matches)")
        return 0
    for r in rows:
        print(f"{r['slug']}  [{r['layer']}·{r['state']}·{r['type'] or '-'}]")
        print(f"    {r['snip']}")
    return 0


def cmd_link(args: argparse.Namespace, instance: Path) -> int:
    slug = args.slug
    layer = _infer_layer(slug)
    path = _path_for(instance, slug, layer)
    if not path.exists():
        print(f"No such entry: {path}", file=sys.stderr)
        return 1

    text = path.read_text(encoding="utf-8")
    target_link = f"[[{args.to}]]"
    if target_link in text:
        print(f"Already linked: {args.to}")
        return 0
    text = text.rstrip() + f"\n\nSee also: {target_link}\n"
    path.write_text(text, encoding="utf-8")

    conn = connect(instance)
    try:
        entry = parse_markdown(path, instance)
        upsert(conn, entry)
        conn.commit()
    finally:
        conn.close()

    _log(instance, "link", slug, f"→ {args.to}")
    return 0


def cmd_lint(_args: argparse.Namespace, instance: Path) -> int:
    conn = connect(instance)
    issues = 0
    try:
        rows = conn.execute("SELECT from_slug, to_slug FROM backlinks").fetchall()
        slugs = {r["slug"] for r in conn.execute("SELECT slug FROM entries").fetchall()}
        for r in rows:
            if r["to_slug"] not in slugs:
                print(f"[broken-link] {r['from_slug']} → {r['to_slug']}")
                issues += 1

        for slug in sorted(slugs):
            row = conn.execute("SELECT layer FROM entries WHERE slug = ?", (slug,)).fetchone()
            if row["layer"] != "L2":
                continue
            in_ = conn.execute("SELECT 1 FROM backlinks WHERE to_slug = ? LIMIT 1", (slug,)).fetchone()
            out_ = conn.execute("SELECT 1 FROM backlinks WHERE from_slug = ? LIMIT 1", (slug,)).fetchone()
            if not in_ and not out_:
                print(f"[orphan] {slug}")
                issues += 1

        rows = conn.execute(
            "SELECT slug, last_verified, state FROM entries WHERE last_verified IS NOT NULL AND last_verified != ''"
        ).fetchall()
        for r in rows:
            try:
                d = date.fromisoformat(r["last_verified"][:10])
            except ValueError:
                continue
            age = (date.today() - d).days
            if age > 90 and r["state"] == "verified":
                print(f"[stale>90d] {r['slug']}  last_verified={r['last_verified']}  age={age}d")
                issues += 1
    finally:
        conn.close()

    print("lint: clean" if issues == 0 else f"lint: {issues} issue(s)")
    return 0


def cmd_log(args: argparse.Namespace, instance: Path) -> int:
    log_path = instance / "memory" / "LOG.md"
    if not log_path.exists():
        return 0
    lines = log_path.read_text(encoding="utf-8").splitlines()
    n = args.n or 20
    for line in lines[-n:]:
        print(line)
    return 0


def cmd_rebuild(_args: argparse.Namespace, instance: Path) -> int:
    conn = connect(instance)
    try:
        ups, gone, skipped = rebuild(conn, instance)
        msg = f"rebuild: {ups} entries upserted, {gone} removed"
        if skipped:
            msg += f", {skipped} skipped (see stderr)"
        print(msg)
    finally:
        conn.close()
    _write_index(instance)
    print("INDEX.md regenerated")
    _ensure_claude_md(instance)
    return 0


def _ensure_claude_md(instance: Path) -> None:
    """Write CLAUDE.md at the instance root if it doesn't exist yet.

    Claude Code auto-loads this file when a session starts in the instance
    dir. The template @imports L1 memory so identity + user profile + rules
    are always in context. Migration path for instances scaffolded before
    this feature existed.
    """
    target = instance / "CLAUDE.md"
    if target.exists():
        return
    # Source the framework's template
    template = (
        Path(__file__).resolve().parent.parent
        / "templates"
        / "init-instance"
        / "CLAUDE.md"
    )
    if not template.exists():
        return
    target.write_text(template.read_text(encoding="utf-8"), encoding="utf-8")
    print(f"wrote {target}")


def cmd_consolidate(_args: argparse.Namespace, _instance: Path) -> int:
    print("consolidate: not yet implemented (auto-dream placeholder)")
    return 0


# --- main --------------------------------------------------------------------


def build_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(prog="jc-memory")
    p.add_argument(
        "--instance-dir",
        help="Instance directory (else $JC_INSTANCE_DIR, else walk up for .jc, else cwd).",
    )
    sub = p.add_subparsers(dest="cmd", required=True)

    pn = sub.add_parser("new", help="Create a new entry")
    pn.add_argument("slug")
    pn.add_argument("--title")
    pn.add_argument("--layer", choices=["L1", "L2"])
    pn.add_argument("--type")
    pn.add_argument("--state", default="draft", choices=["draft", "reviewed", "verified", "active", "stale", "archived"])
    pn.add_argument("--tag", action="append")
    pn.add_argument("--link", action="append")
    pn.add_argument("--body")
    pn.set_defaults(func=cmd_new)

    pw = sub.add_parser("write", help="Replace body of an existing entry (stdin or --body-file)")
    pw.add_argument("slug")
    pw.add_argument("--body-file")
    pw.set_defaults(func=cmd_write)

    pr = sub.add_parser("read", help="Print an entry by slug")
    pr.add_argument("slug")
    pr.set_defaults(func=cmd_read)

    ps = sub.add_parser("search", help="FTS5 ranked search")
    ps.add_argument("query")
    ps.add_argument("--limit", type=int, default=10)
    ps.set_defaults(func=cmd_search)

    pl = sub.add_parser("link", help="Add a [[wikilink]] from slug to target")
    pl.add_argument("slug")
    pl.add_argument("--to", required=True)
    pl.set_defaults(func=cmd_link)

    plint = sub.add_parser("lint", help="Broken links, orphans, staleness")
    plint.set_defaults(func=cmd_lint)

    plg = sub.add_parser("log", help="Tail LOG.md")
    plg.add_argument("n", type=int, nargs="?", default=20)
    plg.set_defaults(func=cmd_log)

    prb = sub.add_parser("rebuild", help="Re-scan .md files and sync DB + INDEX.md")
    prb.set_defaults(func=cmd_rebuild)

    pc = sub.add_parser("consolidate", help="Auto-dream placeholder")
    pc.set_defaults(func=cmd_consolidate)

    return p


def main(argv: list[str] | None = None) -> int:
    parser = build_parser()
    args = parser.parse_args(argv)
    instance = resolve_instance_dir(args.instance_dir)
    return args.func(args, instance)


if __name__ == "__main__":
    sys.exit(main())
